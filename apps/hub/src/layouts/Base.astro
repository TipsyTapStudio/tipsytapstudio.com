---
// Hub base layout — global <html>/<head>/<body>/<main>/<footer> shell.
//
// Design principles:
// - Mobile-first, single-column, generous whitespace.
// - JS-zero by default. Motion = CSS only, respects prefers-reduced-motion.
// - Monochrome (PRD §4 "色階層"). Hub stays desaturated; product LPs colorize.
// - One typographic family (IBM Plex Sans + IBM Plex Sans JP, self-hosted via
//   @fontsource) shared across subdomains. JP is loaded only at 400/600 for weight budget.

import { t, type Locale } from '@ttsui/i18n';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HubBrewBackground from '../components/HubBrewBackground.astro';

// Self-hosted IBM Plex Sans via @fontsource (same-origin, no third-party requests).
// Keep weight list in sync with typography.weights in @ttsui/tokens.
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
// JP companion — japanese subset only, 400/600 weights (designer-set budget).
import '@fontsource/ibm-plex-sans-jp/japanese-400.css';
import '@fontsource/ibm-plex-sans-jp/japanese-600.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;

const siteTitle = title ?? 'Tipsy Tap Studio';
const siteDescription =
  description ??
  'An experimental room for music as interactive experience — Tipsy Tap Studio.';

// Locale switcher target. Pages live under /ja/ and /en/ only, so flipping
// the prefix is enough until deeper routes exist.
const otherLocale: Locale = locale === 'ja' ? 'en' : 'ja';
const switchHref = `/${otherLocale}/`;
const switchLabel = t('common_locale_switch', locale);

// --- Brew background enable/disable ---
// Hub pages get the sticky Brew background; /lab/ pages already host their
// own Lab #002 BrewCanvas inside an ExperimentFrame and must NOT stack a
// second WebGL canvas behind them. Guarded explicitly by pathname.
const enableBrewBg = !Astro.url.pathname.includes('/lab/');
// Header (N2) follows the same guard — /lab/ runs its own ExperimentFrame
// chrome and shouldn't carry the hub's fixed nav over the top of it.
const enableHeader = enableBrewBg;

---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* IBM Plex Sans (+ JP) is bundled via @fontsource (imported in frontmatter).
        No external font requests — privacy-friendly and zero third-party DNS.
        TODO(engineer): consider <link rel="preload"> for the latin 400 woff2 once
        the @fontsource asset path is stable post-build, to shave LCP. */}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    {/* Sticky Brew background — body-direct child, behind <main>.
        Disabled on /lab/ to avoid stacking two WebGL canvases. */}
    <HubBrewBackground enable={enableBrewBg} />

    {/* Fixed nav — transparent over Hero, chip-bar after the Hero sentinel
        scrolls off. Same /lab/ guard as the Brew background. */}
    {enableHeader && (
      <Header locale={locale} switchHref={switchHref} otherLocale={otherLocale} />
    )}

    <main id="main">
      <slot />
    </main>

    <Footer
      locale={locale}
      switchHref={switchHref}
      switchLabel={switchLabel}
      otherLocale={otherLocale}
    />
  </body>
</html>

<style is:global>
  /* --- Tokens (mirrored from @ttsui/tokens for global CSS) --- */
  :root {
    --bg: #0b0b0b;
    --fg: #ededed;
    --muted: #9a9a9a;
    --rule: #1f1f1f;
    /* Border-hairline is intentionally a distinct token from --rule even though
       the value matches today. Components use --border-hairline so the designer
       can lift card borders without touching divider rules. */
    --border-hairline: #1f1f1f;
    --badge-fg-mono: #3a3a3a;
    --badge-beta-bg: #2a2a2a;

    --font-sans:
      'IBM Plex Sans', ui-sans-serif, system-ui, -apple-system, 'Segoe UI',
      'Hiragino Sans', 'Noto Sans JP', sans-serif;

    --tracking-heading: 0.04em;
    --tracking-body: 0.01em;
    --track-display: 0.12em;
    --track-badge: 0.08em;

    --lh-tight: 1.15;
    --lh-normal: 1.6;

    --space-3xs: 0.25rem;
    --space-2xs: 0.5rem;
    --space-xs: 0.75rem;
    --space-sm: 1rem;
    --space-md: 1.5rem;
    --space-lg: 2rem;
    --space-xl: 3rem;
    --space-2xl: 4.5rem;
    --space-3xl: 6rem;
    --space-section: clamp(4.5rem, 3rem + 6vw, 8rem);
    --space-section-sm: clamp(3rem, 2rem + 3vw, 4.5rem);

    --fs-xs: clamp(0.75rem, 0.72rem + 0.15vw, 0.8125rem);
    --fs-sm: clamp(0.875rem, 0.84rem + 0.18vw, 0.95rem);
    --fs-base: clamp(1rem, 0.96rem + 0.2vw, 1.125rem);
    --fs-lg: clamp(1.125rem, 1.05rem + 0.4vw, 1.375rem);
    --fs-xl: clamp(2rem, 1.4rem + 3vw, 3.75rem);
    --fs-2xl: clamp(2.5rem, 1.6rem + 4.5vw, 5rem);
    --fs-3xl: clamp(3rem, 2rem + 5vw, 6rem);

    --radius-card: 0.5rem;
    --radius-chip: 999px;

    --max-content: 56rem; /* ~896px — comfortable single-column reading width */

    /* --- Brew background overlay tokens ---
       Used by hub section backgrounds (Works / Manifesto / About / Footer
       band / ProductCard / Hero scroll cue) to remain legible while the
       Brew WebGL background scrolls underneath. See @ttsui/tokens
       (overlay, cardOnBrew, textShadowOnBrew). */
    --overlay-soft: rgba(11, 11, 11, 0.35);
    --overlay-strong: rgba(11, 11, 11, 0.6);
    --card-bg-onbrew: rgba(11, 11, 11, 0.55);
    --card-border-onbrew: rgba(255, 255, 255, 0.08);
    --text-shadow-onbrew: 0 1px 2px rgba(0, 0, 0, 0.45);

    /* --- Lab-scope tokens (used only under /lab/) ---
       Mirrored from @ttsui/tokens `lab`. Hub Hero / Works / Manifesto must NOT
       consume --lab-shade-1 / --lab-shade-2 — those are reserved for Drift's
       grayscale conic-gradient. See CLAUDE.md §"ブランド適用原則". */
    --lab-canvas-min-h: 100svh;
    --lab-shade-1: #1A1A1A;
    --lab-shade-2: #262626;
    --lab-shade-2-hi: #4A4A4A;
    --lab-drift-blur: 40px;
    --lab-grain-alpha-max: 0.55;
    --lab-overlay-bg: rgba(11, 11, 11, 0.6);
    --ease-flux: cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* --- Minimal reset --- */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  html {
    -webkit-text-size-adjust: 100%;
  }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    font-size: var(--fs-base);
    line-height: 1.6;
    letter-spacing: var(--tracking-body);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Japanese family override — JP glyph family fronted, latin Plex Sans as the
     fallback so mixed-script lines keep a unified Plex feel. System stack stays
     as the last-resort fallback for font load failures. */
  :lang(ja) {
    font-family: 'IBM Plex Sans JP', 'IBM Plex Sans', ui-sans-serif, system-ui,
      -apple-system, 'Segoe UI', 'Hiragino Sans', 'Noto Sans JP', sans-serif;
  }

  /* Heading tracking — euro-Latin gets the 0.04em document feel.
     Japanese (kana/kanji) looks airy and broken at that value, so reset to 0. */
  h1,
  h2,
  h3 {
    letter-spacing: var(--tracking-heading);
  }

  :lang(ja) h1,
  :lang(ja) h2,
  :lang(ja) h3 {
    letter-spacing: 0;
  }

  main {
    flex: 1 0 auto;
    width: 100%;
  }

  a {
    color: inherit;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  a:hover {
    text-decoration-thickness: 2px;
  }

  /* --- Skip link (a11y) --- */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--fg);
    color: var(--bg);
    padding: var(--space-2xs) var(--space-sm);
    /* Sits above .site-nav (z-index 50) so it remains visible on focus. */
    z-index: 60;
  }
  .skip-link:focus {
    left: var(--space-sm);
    top: var(--space-sm);
  }

  /* --- Section heading utility (used by all top-level sections) --- */
  .section-heading {
    font-size: var(--fs-xl);
    font-weight: 500;
    line-height: var(--lh-tight);
    letter-spacing: var(--track-display);
    margin: 0 0 var(--space-md);
    color: var(--fg);
  }

  @media (min-width: 640px) {
    .section-heading {
      margin-bottom: var(--space-lg);
    }
  }

  @media (min-width: 1024px) {
    .section-heading {
      margin-bottom: var(--space-xl);
    }
  }

  /* Japanese tightens display tracking; the wide 0.12em looks broken in kana. */
  .section-heading:lang(ja) {
    letter-spacing: 0.04em;
  }

  /* Shared section layout utility — single-column, fluid vertical rhythm. */
  .section {
    max-width: var(--max-content);
    margin: 0 auto;
    padding-inline: var(--space-md);
    padding-block: var(--space-xl);
  }

  @media (min-width: 640px) {
    .section {
      padding-inline: var(--space-xl);
      padding-block: var(--space-2xl);
    }
  }

  @media (min-width: 1024px) {
    .section {
      padding-inline: var(--space-2xl);
      padding-block: var(--space-section);
    }
  }

  .section-lede {
    color: var(--muted);
    font-size: var(--fs-base);
    line-height: var(--lh-normal);
    max-width: 38rem;
    margin: 0 0 var(--space-lg);
  }
</style>
