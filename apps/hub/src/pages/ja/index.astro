---
// Hub — Japanese landing page (Phase 1 full: Hero / Works / Manifesto / About).
//
// Copy lives in @ttsui/i18n; layout tokens come from Base.astro :root.
// Page-level shell only — visual rules belong to the components.

import Base from '../../layouts/Base.astro';
import { t } from '@ttsui/i18n';
import SectionHeading from '../../components/SectionHeading.astro';
import ProductCard from '../../components/ProductCard.astro';
import { sortWorks, type Work } from '../../lib/sortWorks.ts';
import worksRaw from '../../data/works.json' with { type: 'json' };

const locale = 'ja';

const title = t('hub_hero_title', locale);
// hub_hero_subtitle (= "鳴らす、光らす、刻む。") is rendered as span-split
// markup below for visual rhythm (designer spec). The i18n key value stays
// canonical in ja.json; this page hard-codes the split form intentionally.
const substatement = t('hub_hero_substatement', locale);

const works = sortWorks(worksRaw as Work[]);
---

<Base locale={locale} title={title} description={substatement}>
  <section class="hero" aria-labelledby="hero-title">
    {/* Font Set C — H1 縦 3 段詰み (英字統一)。
        ja でもブランド名 "Tipsy Tap Studio" は英字のまま縦 3 段で見せる。
        i18n の hub_hero_title は <title> / aria のために frontmatter で参照済み。 */}
    <h1 id="hero-title" class="hero__title hero__title--vertical" aria-label={title}>
      <span class="hero__word">Tipsy</span>
      <span class="hero__word">Tap</span>
      <span class="hero__word">Studio</span>
    </h1>
    <p class="hero__statement" aria-label="鳴らす、光らす、刻む。">
      <span class="beat">鳴らす</span><span class="sep">、</span><span class="beat">光らす</span><span class="sep">、</span><span class="beat">刻む</span>。
    </p>
    <p class="hero__sub">{substatement}</p>
  </section>

  {/* Each section is wrapped in a full-width band so the Brew overlay can
      cover the entire viewport width while the inner .section keeps its
      max-width text column. */}
  <div class="section-band section-band--soft">
    <section id="works" class="section" aria-labelledby="works-heading">
      <SectionHeading id="works-heading">{t('hub_works_heading', locale)}</SectionHeading>
      <p class="section-lede">{t('hub_works_lede', locale)}</p>
      <ul class="works-grid" role="list">
        {works.map((work) => (
          <li>
            <ProductCard
              slug={work.slug}
              status={work.status}
              tags={work.tags}
              thumb={work.thumb}
              demoUrl={work.demoUrl}
              repoUrl={work.repoUrl}
              lpUrl={work.lpUrl}
              locale={locale}
            />
          </li>
        ))}
      </ul>
    </section>
  </div>

  <div class="section-band section-band--strong">
    <section id="about" class="section" aria-labelledby="about-heading">
      <SectionHeading id="about-heading">{t('hub_about_heading', locale)}</SectionHeading>
      <p class="about__body">{t('hub_about_body', locale)}</p>
      <span class="about__placeholder">{t('hub_about_devlog_link', locale)}</span>
    </section>
  </div>
</Base>

<style>
  .hero {
    max-width: var(--max-content);
    margin: 0 auto;
    /* 2026-05-30 一発確定: flex → grid 1fr auto auto に転換。
       X5 失敗の真因は (1) min-height で box が viewport より短い (2) center
       が塊重心配置 (3) padding-bottom > padding-top が flex で逆作用、の
       3 つの誤りの掛け算。今回は H1 単独を 1fr 行の中央に数学的固定。
       height: 100dvh で box = viewport ぴったり。
       padding-top 14rem (Header 補正 + 下バイアス強め、ユーザー指定値)。
       試算: H1 中央線が viewport 中央 +25〜27px 下に着地。 */
    height: 100dvh;
    padding-top: 14rem;
    padding-bottom: 3rem;
    padding-inline: clamp(1.25rem, 0.5rem + 3vw, 4rem);
    display: grid;
    grid-template-rows: 1fr auto auto;  /* 1fr=H1中央 / auto=statement / auto=sub */
    justify-items: start;
    row-gap: var(--space-md);
    position: relative;
    isolation: isolate; /* radial dim ::before を hero スコープに閉じ込める */
  }

  /* 2026-05-30: .hero::before (radial dim 座布団) 削除。
     コントラストは text-shadow 強化側で確保する方針へ。 */

  .hero__statement .sep {
    margin-inline-end: 0.25em; /* TODO by designer: 0.2-0.35em で実機確認後確定 */
  }

  /* Font Set C Hero H1 — 縦 3 段詰み (英字 "Tipsy / Tap / Studio")。
     ja でもブランドネームは英字なので Fraunces 軸をそのまま効かせる。 */
  .hero__title--vertical {
    /* grid item として 1fr 行の中央に配置 */
    align-self: center;
    justify-self: start;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    margin: 0;
    /* :lang(ja) では --font-display = Noto Serif JP だが、英字グリフは
       fallback で Fraunces Variable に落ちる (fontFamily 順序の通り)。 */
    font-family: 'Fraunces Variable', 'Fraunces', var(--font-display);
    font-size: clamp(3.5rem, 2.4rem + 7vw, 9.5rem);
    font-weight: 600;
    line-height: 0.88;
    letter-spacing: -0.03em;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    /* 2026-05-30: 座布団削除に伴い text-shadow をローカル強化
       (--text-shadow-onbrew トークンは Header 等で継続使用するため非変更)。 */
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6), 0 0 16px rgba(0, 0, 0, 0.4);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  .hero__word {
    display: block;
  }

  .hero__statement {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 1rem + 1.5vw, 2.25rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0;
    margin: 0;
    color: var(--fg);
    /* statement を副題に降格 — opsz=72, SOFT=50 でやわらかく。
       Noto Serif JP は variable ではないが、無視されるだけで害なし。 */
    font-variation-settings: 'opsz' 72, 'SOFT' 50;
    /* 2026-05-30: 座布団削除に伴い text-shadow ローカル強化。 */
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6), 0 0 16px rgba(0, 0, 0, 0.4);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) 120ms both;
    /* ja: 「鳴らす、光らす、刻む。」9 文字、絶対 1 行維持 */
    white-space: nowrap;
  }

  .hero__sub {
    font-size: var(--fs-base);
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
    /* 2026-05-30: muted → muted-onbrew で Pilsner colB 上でも WCAG AA 確保。
       text-shadow も座布団削除分を補う強化。 */
    color: var(--muted-onbrew);
    max-width: 32rem;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.65), 0 0 10px rgba(0, 0, 0, 0.35);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) 240ms both;
  }

  /* --- Full-width Brew overlay bands ---
     The inner .section keeps its max-width text column; the band paints the
     viewport-wide overlay so the Brew layer reads as a continuous backdrop
     with sections "settling" on top. */
  .section-band {
    width: 100%;
  }
  /* 2026-05-28: overlay 階段が「区切り線」として見える指摘を受けて
     段差を解消、全セクション透明化。文字可読性は text-shadow 側で確保 */
  .section-band--soft,
  .section-band--strong {
    background: transparent;
  }

  /* Sections */
  .works-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .works-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .about__body {
    color: var(--fg);
    font-size: var(--fs-base);
    line-height: var(--lh-normal);
    max-width: 38rem;
    margin: 0 0 var(--space-md);
  }

  .about__placeholder {
    display: inline-block;
    color: var(--muted);
    font-size: var(--fs-sm);
    border-bottom: 1px dashed var(--rule);
    padding-bottom: 2px;
  }

  /* 640+/1024+ の .hero padding/gap 上書きは削除済み。
     .hero の clamp() が全幅で padding を吸収する。 */

  @keyframes hero-fade {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__title,
    .hero__title--vertical,
    .hero__statement,
    .hero__sub {
      animation: none;
    }
  }
</style>
