---
// Hub — Japanese landing page (Phase 1 full: Hero / Works / Manifesto / About).
//
// Copy lives in @ttsui/i18n; layout tokens come from Base.astro :root.
// Page-level shell only — visual rules belong to the components.

import Base from '../../layouts/Base.astro';
import { t } from '@ttsui/i18n';
import SectionHeading from '../../components/SectionHeading.astro';
import ProductCard from '../../components/ProductCard.astro';
import { sortWorks, type Work } from '../../lib/sortWorks.ts';
import worksRaw from '../../data/works.json' with { type: 'json' };

const locale = 'ja';

const title = t('hub_hero_title', locale);
// hub_hero_subtitle (= "鳴らす、光らす、刻む。") is rendered as span-split
// markup below for visual rhythm (designer spec). The i18n key value stays
// canonical in ja.json; this page hard-codes the split form intentionally.
const substatement = t('hub_hero_substatement', locale);

const works = sortWorks(worksRaw as Work[]);
const skipLabel = t('hub_nav_skip_to_works', locale);
---

<Base locale={locale} title={title} description={substatement}>
  <section class="hero" aria-labelledby="hero-title">
    {/* H3 階段状縦 3 段 — ja でも英字 "Tipsy / Tap / Studio" で統一.
        VRSM 流の brand 原則 (英字 wordmark は全 locale 共通)。
        aria-label に i18n の title (= "Tipsy Tap Studio") を渡す. */}
    <h1
      id="hero-title"
      class="hero__title hero__title--stacked"
      aria-label={title}
      lang="en"
    >
      <span class="hero__word hero__word--1">Tipsy</span>
      <span class="hero__word hero__word--2">Tap</span>
      <span class="hero__word hero__word--3">Studio</span>
    </h1>
    {/* ja statement — italic 概念がないので「文字を 1 段薄くして格を出す」.
        font-weight 400 + muted color + dotted underline で繊細に酒場感を出す.
        (デザイナー指示外、エンジニア裁量・要レビュー — TODO by designer) */}
    <p class="hero__statement hero__statement--menu" aria-label="鳴らす、光らす、刻む。">
      <span class="hero__statement-rule" aria-hidden="true">──</span>
      <span class="beat">鳴らす</span><span class="sep">、</span><span class="beat">光らす</span><span class="sep">、</span><span class="beat">刻む</span>。
    </p>
    <p class="hero__sub">{substatement}</p>

    <a class="hero__cue" href="#works" aria-label={skipLabel}>
      <span aria-hidden="true">↓</span>
    </a>

    {/* Sentinel — Header watches this via IO; once it leaves the viewport,
        the nav switches from transparent to chip-bar mode. Sits at the very
        end of Hero so the toggle fires right as Hero scrolls off. */}
    <div data-nav-sentinel aria-hidden="true"></div>
  </section>

  {/* Each section is wrapped in a full-width band so the Brew overlay can
      cover the entire viewport width while the inner .section keeps its
      max-width text column. */}
  <div class="section-band section-band--soft">
    <section id="works" class="section" aria-labelledby="works-heading">
      <SectionHeading id="works-heading">{t('hub_works_heading', locale)}</SectionHeading>
      <p class="section-lede">{t('hub_works_lede', locale)}</p>
      <ul class="works-grid" role="list">
        {works.map((work) => (
          <li>
            <ProductCard
              slug={work.slug}
              status={work.status}
              tags={work.tags}
              thumb={work.thumb}
              demoUrl={work.demoUrl}
              repoUrl={work.repoUrl}
              lpUrl={work.lpUrl}
              locale={locale}
            />
          </li>
        ))}
      </ul>
    </section>
  </div>

  <div class="section-band section-band--strong">
    <section id="about" class="section" aria-labelledby="about-heading">
      <SectionHeading id="about-heading">{t('hub_about_heading', locale)}</SectionHeading>
      <p class="about__body">{t('hub_about_body', locale)}</p>
      <span class="about__placeholder">{t('hub_about_devlog_link', locale)}</span>
    </section>
  </div>
</Base>

<style>
  .hero {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
    min-height: calc(100svh - 6rem); /* leave room for footer */
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-md);
    position: relative;
    isolation: isolate; /* radial-dim ::before の z-index: -1 をこの stacking に閉じる */
  }

  /* Hero 左寄せの階段組みに合わせて、左 30% に radial dim を寄せる. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 30% center,
      rgba(0, 0, 0, 0.35) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  .hero__statement .sep {
    margin-inline-end: 0.25em; /* TODO by designer: 0.2-0.35em で実機確認後確定 */
  }

  .hero__title {
    font-size: var(--fs-2xl);
    font-weight: 600;
    /* letter-spacing handled globally in Base.astro (h1 + :lang(ja) override) */
    line-height: 1.05;
    margin: 0;
    /* Brew background sits behind the hero — shadow rescues legibility on the
       hotter palette ranges (pilsner/ipa peaks). */
    text-shadow: var(--text-shadow-onbrew);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  /* H3 階段状 — en と同じ Tipsy / Tap / Studio をインデント.
     英字 wordmark のため :lang(ja) tracking 0 ルールの上に -0.02em で締める. */
  .hero__title--stacked {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    font-size: clamp(3rem, 2rem + 6vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    font-weight: 500;
  }

  .hero__word {
    display: block;
  }
  .hero__word--1 { padding-left: 0; }
  .hero__word--2 { padding-left: 2ch; }
  .hero__word--3 { padding-left: 4ch; }

  .hero__statement {
    font-size: var(--fs-xl);
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    color: var(--fg);
    text-shadow: var(--text-shadow-onbrew);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) 120ms both;
  }

  /* ja menu statement — italic がない代わりに文字を 1 段薄く + dotted underline
     で繊細に酒場感を出す。font-size は en と同様にやや小さく品格寄り.
     TODO by designer: 装飾の濃度 (opacity / underline-color) を実機で確定. */
  .hero__statement--menu {
    font-size: var(--fs-lg);
    font-weight: 400;
    color: var(--muted);
    display: flex;
    align-items: baseline;
    gap: 0.6em;
    flex-wrap: wrap;
    text-decoration: underline dotted rgba(237, 237, 237, 0.25);
    text-underline-offset: 0.35em;
    text-decoration-thickness: 1px;
  }
  .hero__statement--menu .beat {
    color: var(--fg); /* キーワードだけ通常色に持ち上げてリズムを作る */
  }
  .hero__statement-rule {
    color: var(--muted);
    letter-spacing: 0;
  }

  .hero__sub {
    font-size: var(--fs-base);
    font-weight: 400;
    line-height: 1.5;
    margin-block-start: var(--space-lg);
    margin-block-end: 0;
    margin-inline: 0;
    color: var(--muted);
    max-width: 32rem;
    /* Slightly stronger shadow on the muted subtitle (lower contrast vs Brew). */
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.5);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) 240ms both;
  }

  /* Scroll cue — real link (a11y), gentle downward bob, never auto-emoji.
     Chip-ified on Brew: subtle dark bubble + backdrop blur so the ↓ stays
     readable against any beer palette. */
  .hero__cue {
    position: absolute;
    left: 50%;
    bottom: var(--space-lg);
    transform: translateX(-50%);
    color: var(--muted);
    font-size: var(--fs-lg);
    line-height: 1;
    text-decoration: none;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: var(--radius-chip);
    background: rgba(11, 11, 11, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: color 120ms ease;
    animation: cue-bob 2400ms ease-in-out infinite;
  }

  .hero__cue:hover,
  .hero__cue:focus-visible {
    color: var(--fg);
  }

  /* --- Full-width Brew overlay bands ---
     The inner .section keeps its max-width text column; the band paints the
     viewport-wide overlay so the Brew layer reads as a continuous backdrop
     with sections "settling" on top. */
  .section-band {
    width: 100%;
  }
  /* 2026-05-28: overlay 階段が「区切り線」として見える指摘を受けて
     段差を解消、全セクション透明化。文字可読性は text-shadow 側で確保 */
  .section-band--soft,
  .section-band--strong {
    background: transparent;
  }

  /* backdrop-filter fallback — bump opacity for browsers without filter
     support (older Firefox, some embedded WebViews). */
  @supports not (backdrop-filter: blur(6px)) {
    .hero__cue {
      background: rgba(11, 11, 11, 0.6);
    }
  }

  /* Sections */
  .works-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .works-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .about__body {
    color: var(--fg);
    font-size: var(--fs-base);
    line-height: var(--lh-normal);
    max-width: 38rem;
    margin: 0 0 var(--space-md);
  }

  .about__placeholder {
    display: inline-block;
    color: var(--muted);
    font-size: var(--fs-sm);
    border-bottom: 1px dashed var(--rule);
    padding-bottom: 2px;
  }

  @media (min-width: 640px) {
    .hero {
      padding: var(--space-3xl) var(--space-xl);
      gap: var(--space-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: var(--space-3xl) var(--space-2xl);
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes cue-bob {
    0%, 100% { transform: translate(-50%, 0); }
    50%      { transform: translate(-50%, 0.3rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__title,
    .hero__title--stacked,
    .hero__statement,
    .hero__statement--menu,
    .hero__sub,
    .hero__cue {
      animation: none;
    }
  }
</style>
