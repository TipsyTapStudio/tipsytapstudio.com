---
// Hub — English landing page (Phase 1 full: Hero / Works / Manifesto / About).

import Base from '../../layouts/Base.astro';
import { t } from '@ttsui/i18n';
import SectionHeading from '../../components/SectionHeading.astro';
import ProductCard from '../../components/ProductCard.astro';
import { groupWorksByCategory, type Work } from '../../lib/sortWorks.ts';
import worksRaw from '../../data/works.json' with { type: 'json' };

const locale = 'en';

const title = t('hub_hero_title', locale);
// hub_hero_substatement は meta description で使用継続。
const substatement = t('hub_hero_substatement', locale);

// Works grouped into category blocks; existing sort order kept within each.
const works = groupWorksByCategory(worksRaw as Work[]);
---

<Base locale={locale} title={title} description={substatement}>
  <section class="hero" aria-labelledby="hero-title">
    <h1 id="hero-title" class="hero__title hero__title--vertical">
      <span class="hero__word">Tipsy</span>
      <span class="hero__word">Tap</span>
      <span class="hero__word">Studio</span>
    </h1>
  </section>

  {/* Full-width bands so the Brew overlay covers the viewport; inner
      .section keeps its max-width text column. */}
  <div class="section-band section-band--soft">
    <section id="works" class="section" aria-labelledby="works-heading">
      <SectionHeading id="works-heading">{t('hub_works_heading', locale)}</SectionHeading>
      <div class="works-cats">
        {works.map((group) => (
          <section class="works-cat" aria-labelledby={`works-cat-${group.category}`}>
            <h3 id={`works-cat-${group.category}`} class="works-cat__heading">
              {t(`hub_works_category_${group.category}`, locale)}
            </h3>
            <ul class="works-list" role="list">
              {group.items.map((work) => (
                <li>
                  <ProductCard
                    slug={work.slug}
                    status={work.status}
                    size={work.size ?? 'small'}
                    tags={work.tags}
                    thumb={work.thumb}
                    demoUrl={work.demoUrl}
                    repoUrl={work.repoUrl}
                    lpUrl={work.lpUrl}
                    locale={locale}
                  />
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </section>
  </div>

  <div class="section-band section-band--strong">
    <section id="lab" class="section" aria-labelledby="lab-heading">
      <SectionHeading id="lab-heading">{t('hub_lab_heading', locale)}</SectionHeading>
      <p class="lab-teaser__body">{t('hub_lab_body', locale)}</p>
      <a class="lab-teaser__link" href={`/${locale}/lab/`}>{t('hub_lab_link', locale)}</a>
    </section>
  </div>
</Base>

<style>
  .hero {
    max-width: var(--max-content);
    margin: 0 auto;
    height: 100dvh;
    /* 2026-05-30 上下バランス調整: 大画面で上重すぎ問題を解消、全 viewport
       で 1.06-1.14:1 (上微重 = Header 視覚補正) に収束 */
    padding-top: clamp(7rem, 5rem + 3.2vw, 10rem);
    padding-bottom: clamp(5.5rem, 4rem + 2.6vw, 8rem);
    padding-inline: clamp(1.25rem, 0.5rem + 3vw, 4rem);
    display: grid;
    place-items: center start;
    position: relative;
    isolation: isolate;
  }

  /* Font Set C Hero H1 — 縦 3 段詰み、左寄せ、opsz=144 で巨大化。 */
  .hero__title--vertical {
    /* 既存 grid item 配置 (place-items: center start) で中央に配置されるので
       align-self/justify-self は不要 */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    margin: 0;
    font-family: 'Fraunces Variable', 'Fraunces', var(--font-display);
    font-size: clamp(4.5rem, 2rem + 13vw, 14rem);
    font-weight: 600;
    line-height: 0.86;
    letter-spacing: -0.035em;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;

    /* --- ガラス感: 半透明塗り (枠線ではない) ---
       前回 (1b52a6a) text-stroke + transparent で「ただの枠線」になり失敗。
       ユーザー直言「ちょっとだけ透明」= 塗りに alpha かけて Brew が
       透けて見える状態。stroke は使わず、塗りベースで実現。 */
    color: rgba(239, 231, 214, 0.55);  /* #EFE7D6 alpha 0.55、Brew がうっすら透ける */
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.5));  /* 文字下の影で立体感 */

    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  .hero__word {
    display: block;
  }

  /* Full-width Brew overlay bands — see ja/index.astro for rationale. */
  .section-band {
    width: 100%;
  }
  /* 2026-05-28: overlay 階段が「区切り線」として見える指摘を受けて
     段差を解消、全セクション透明化。文字可読性は text-shadow 側で確保 */
  .section-band--soft,
  .section-band--strong {
    background: transparent;
  }

  /* Works — category blocks of horizontal cards. 3-col grid removed
     (2026-05-30 restructure). */
  .works-cats {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .works-cat__heading {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 40, 'SOFT' 30;
    font-size: var(--fs-lg);
    font-weight: 500;
    line-height: var(--lh-tight);
    color: var(--fg);
    margin: 0 0 var(--space-md);
    text-shadow: var(--text-shadow-onbrew);
  }

  .works-cat__heading:lang(ja) {
    letter-spacing: 0.02em;
  }

  .works-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .lab-teaser__body {
    color: var(--fg);
    font-size: var(--fs-base);
    line-height: var(--lh-normal);
    max-width: 42rem;
    margin: 0 0 var(--space-md);
    /* Halo so the prose stays legible over the brightest Brew (same token as
       the Works category headings). */
    text-shadow: var(--text-shadow-onbrew);
  }

  /* Understated underline CTA (same family as card__cta) — the teaser is a
     light nudge, not a button. No blur plate behind it (unlike cards), so the
     underline uses a warm-white tint that survives the bright Brew. */
  .lab-teaser__link {
    display: inline-block;
    color: var(--fg);
    font-size: var(--fs-sm);
    text-decoration: none;
    border-bottom: 1px solid rgba(239, 231, 214, 0.4);
    padding-bottom: 2px;
    text-shadow: var(--text-shadow-onbrew);
    transition: border-color 120ms ease;
  }

  .lab-teaser__link:hover,
  .lab-teaser__link:focus-visible {
    border-color: var(--fg);
  }

  /* 640+/1024+ の .hero padding/gap 上書きは削除済み。
     .hero の clamp() が全幅で padding を吸収する。 */

  @keyframes hero-fade {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__title,
    .hero__title--vertical {
      animation: none;
    }
    .lab-teaser__link {
      transition: none;
    }
  }
</style>
