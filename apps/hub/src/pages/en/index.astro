---
// Hub — English landing page (Phase 1 full: Hero / Works / Manifesto / About).

import Base from '../../layouts/Base.astro';
import { t } from '@ttsui/i18n';
import SectionHeading from '../../components/SectionHeading.astro';
import ProductCard from '../../components/ProductCard.astro';
import { sortWorks, type Work } from '../../lib/sortWorks.ts';
import worksRaw from '../../data/works.json' with { type: 'json' };

const locale = 'en';

const title = t('hub_hero_title', locale);
const subtitle = t('hub_hero_subtitle', locale);
const substatement = t('hub_hero_substatement', locale);

const works = sortWorks(worksRaw as Work[]);
const skipLabel = t('hub_nav_skip_to_works', locale);
---

<Base locale={locale} title={title} description={substatement}>
  <section class="hero" aria-labelledby="hero-title">
    {/* H3 階段状縦 3 段 — Tipsy / Tap / Studio をインデントで階段組み.
        ほろ酔いの「傾き」をタイポで回収。aria-label で screen-reader 用に
        通しの "Tipsy Tap Studio" を伝える (title prop と一致). */}
    <h1
      id="hero-title"
      class="hero__title hero__title--stacked"
      aria-label={title}
    >
      <span class="hero__word hero__word--1">Tipsy</span>
      <span class="hero__word hero__word--2">Tap</span>
      <span class="hero__word hero__word--3">Studio</span>
    </h1>
    {/* 酒場メニュー風 statement — 罫線 ── + 動詞 italic.
        EB Garamond の italic は意味のある変化 (筆記体寄り)、動詞だけ italic に
        振って menu card のリズムを作る。subtitle (i18n) と意図的に乖離させて
        いるので、aria-label に subtitle 原文を渡して a11y を維持。 */}
    <p class="hero__statement hero__statement--menu" aria-label={subtitle}>
      <span class="hero__statement-rule" aria-hidden="true">──</span>
      <em>tap it</em>, <em>light it</em>, <em>let it tick</em>.
    </p>
    <p class="hero__sub">{substatement}</p>

    <a class="hero__cue" href="#works" aria-label={skipLabel}>
      <span aria-hidden="true">↓</span>
    </a>

    {/* Sentinel — Header watches this via IO; once it leaves the viewport,
        the nav switches from transparent to chip-bar mode. */}
    <div data-nav-sentinel aria-hidden="true"></div>
  </section>

  {/* Full-width bands so the Brew overlay covers the viewport; inner
      .section keeps its max-width text column. */}
  <div class="section-band section-band--soft">
    <section id="works" class="section" aria-labelledby="works-heading">
      <SectionHeading id="works-heading">{t('hub_works_heading', locale)}</SectionHeading>
      <p class="section-lede">{t('hub_works_lede', locale)}</p>
      <ul class="works-grid" role="list">
        {works.map((work) => (
          <li>
            <ProductCard
              slug={work.slug}
              status={work.status}
              tags={work.tags}
              thumb={work.thumb}
              demoUrl={work.demoUrl}
              repoUrl={work.repoUrl}
              lpUrl={work.lpUrl}
              locale={locale}
            />
          </li>
        ))}
      </ul>
    </section>
  </div>

  <div class="section-band section-band--strong">
    <section id="about" class="section" aria-labelledby="about-heading">
      <SectionHeading id="about-heading">{t('hub_about_heading', locale)}</SectionHeading>
      <p class="about__body">{t('hub_about_body', locale)}</p>
      <span class="about__placeholder">{t('hub_about_devlog_link', locale)}</span>
    </section>
  </div>
</Base>

<style>
  .hero {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
    min-height: calc(100svh - 6rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-md);
    position: relative;
    isolation: isolate; /* radial-dim ::before の z-index: -1 をこの stacking 内に閉じ込める */
  }

  /* Hero 左 30% に dim を寄せて、階段組みの title 帯を読みやすくする.
     Brew 背景はそのまま見せたいので ellipse + 70% で穏やかにフェード. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 30% center,
      rgba(0, 0, 0, 0.35) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  .hero__title {
    font-size: var(--fs-2xl);
    font-weight: 600;
    line-height: 1.05;
    margin: 0;
    /* Brew background sits behind the hero — shadow rescues legibility. */
    text-shadow: var(--text-shadow-onbrew);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  /* H3 階段状 — Tipsy / Tap / Studio を縦 3 段、左揃いでインデント.
     ほろ酔いの「傾き」をタイポで回収するブランド回収。 */
  .hero__title--stacked {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    /* clamp は仕様通り — fs-2xl より一段大きく、3 段組みのリズムが効く範囲 */
    font-size: clamp(3rem, 2rem + 6vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.02em; /* serif 大判は -0.02em でグリフを締める */
    font-weight: 500;
  }

  .hero__word {
    display: block;
  }
  .hero__word--1 { padding-left: 0; }
  .hero__word--2 { padding-left: 2ch; }
  .hero__word--3 { padding-left: 4ch; }

  .hero__statement {
    font-size: var(--fs-xl);
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    color: var(--fg);
    text-shadow: var(--text-shadow-onbrew);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) 120ms both;
  }

  /* 酒場メニュー風 — 罫線 ── を先頭に、動詞 italic. font-size は title が
     階段組みで主役級になったぶん、statement はやや抑えて menu card 寄りに. */
  .hero__statement--menu {
    font-size: var(--fs-lg);
    font-weight: 400;
    font-style: normal;
    display: flex;
    align-items: baseline;
    gap: 0.6em;
    flex-wrap: wrap;
  }
  .hero__statement--menu em {
    font-style: italic;
    font-weight: 500;
  }
  .hero__statement-rule {
    color: var(--muted);
    letter-spacing: 0;
    /* 罫線は欧文 em-dash 2 連、Brew 上で痩せないよう shadow 継承 */
  }

  .hero__sub {
    font-size: var(--fs-base);
    font-weight: 400;
    line-height: 1.5;
    margin-block-start: var(--space-lg);
    margin-block-end: 0;
    margin-inline: 0;
    color: var(--muted);
    max-width: 42rem; /* en は欧文密度低、ja の 32rem とは別値 */
    /* Slightly stronger shadow on the muted subtitle. */
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.5);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) 240ms both;
  }

  .hero__cue {
    position: absolute;
    left: 50%;
    bottom: var(--space-lg);
    transform: translateX(-50%);
    color: var(--muted);
    font-size: var(--fs-lg);
    line-height: 1;
    text-decoration: none;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: var(--radius-chip);
    background: rgba(11, 11, 11, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: color 120ms ease;
    animation: cue-bob 2400ms ease-in-out infinite;
  }

  .hero__cue:hover,
  .hero__cue:focus-visible {
    color: var(--fg);
  }

  /* Full-width Brew overlay bands — see ja/index.astro for rationale. */
  .section-band {
    width: 100%;
  }
  /* 2026-05-28: overlay 階段が「区切り線」として見える指摘を受けて
     段差を解消、全セクション透明化。文字可読性は text-shadow 側で確保 */
  .section-band--soft,
  .section-band--strong {
    background: transparent;
  }

  @supports not (backdrop-filter: blur(6px)) {
    .hero__cue {
      background: rgba(11, 11, 11, 0.6);
    }
  }

  .works-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .works-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .about__body {
    color: var(--fg);
    font-size: var(--fs-base);
    line-height: var(--lh-normal);
    max-width: 42rem;
    margin: 0 0 var(--space-md);
  }

  .about__placeholder {
    display: inline-block;
    color: var(--muted);
    font-size: var(--fs-sm);
    border-bottom: 1px dashed var(--rule);
    padding-bottom: 2px;
  }

  @media (min-width: 640px) {
    .hero {
      padding: var(--space-3xl) var(--space-xl);
      gap: var(--space-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: var(--space-3xl) var(--space-2xl);
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes cue-bob {
    0%, 100% { transform: translate(-50%, 0); }
    50%      { transform: translate(-50%, 0.3rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__title,
    .hero__title--stacked,
    .hero__statement,
    .hero__statement--menu,
    .hero__sub,
    .hero__cue {
      animation: none;
    }
  }
</style>
