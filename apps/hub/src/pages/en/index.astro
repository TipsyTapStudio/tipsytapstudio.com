---
// Hub — English landing page (Phase 1 full: Hero / Works / Manifesto / About).

import Base from '../../layouts/Base.astro';
import { t } from '@ttsui/i18n';
import SectionHeading from '../../components/SectionHeading.astro';
import ProductCard from '../../components/ProductCard.astro';
import { sortWorks, type Work } from '../../lib/sortWorks.ts';
import worksRaw from '../../data/works.json' with { type: 'json' };

const locale = 'en';

const title = t('hub_hero_title', locale);
const subtitle = t('hub_hero_subtitle', locale);
const substatement = t('hub_hero_substatement', locale);

const works = sortWorks(worksRaw as Work[]);
const skipLabel = t('hub_nav_skip_to_works', locale);
---

<Base locale={locale} title={title} description={substatement}>
  <section class="hero" aria-labelledby="hero-title">
    {/* Font Set C — H1 縦 3 段詰み。en は語ごとに span 化して
        flex-direction: column で巨大化させ、opsz=144 を効かせる。
        ja は単一文字列のままにして同じ縦詰みクラスを与える (`hero__title--vertical` の
        flex column が日本語タイトルでも左寄せ巨大化を担保)。 */}
    <h1 id="hero-title" class="hero__title hero__title--vertical">
      <span class="hero__word">Tipsy</span>
      <span class="hero__word">Tap</span>
      <span class="hero__word">Studio</span>
    </h1>
    <p class="hero__statement">{subtitle}</p>
    <p class="hero__sub">{substatement}</p>

    <a class="hero__cue" href="#works" aria-label={skipLabel}>
      <span aria-hidden="true">↓</span>
    </a>

    {/* Sentinel — Header watches this via IO; once it leaves the viewport,
        the nav switches from transparent to chip-bar mode. */}
    <div data-nav-sentinel aria-hidden="true"></div>
  </section>

  {/* Full-width bands so the Brew overlay covers the viewport; inner
      .section keeps its max-width text column. */}
  <div class="section-band section-band--soft">
    <section id="works" class="section" aria-labelledby="works-heading">
      <SectionHeading id="works-heading">{t('hub_works_heading', locale)}</SectionHeading>
      <p class="section-lede">{t('hub_works_lede', locale)}</p>
      <ul class="works-grid" role="list">
        {works.map((work) => (
          <li>
            <ProductCard
              slug={work.slug}
              status={work.status}
              tags={work.tags}
              thumb={work.thumb}
              demoUrl={work.demoUrl}
              repoUrl={work.repoUrl}
              lpUrl={work.lpUrl}
              locale={locale}
            />
          </li>
        ))}
      </ul>
    </section>
  </div>

  <div class="section-band section-band--strong">
    <section id="about" class="section" aria-labelledby="about-heading">
      <SectionHeading id="about-heading">{t('hub_about_heading', locale)}</SectionHeading>
      <p class="about__body">{t('hub_about_body', locale)}</p>
      <span class="about__placeholder">{t('hub_about_devlog_link', locale)}</span>
    </section>
  </div>
</Base>

<style>
  .hero {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-md);
    min-height: calc(100svh - 6rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-md);
    position: relative;
    isolation: isolate; /* radial dim ::before を hero スコープに閉じ込める */
  }

  /* Radial dim — Hero 左 30% を暗く落として H1 のコントラストを稼ぐ。
     Brew 背景の上に重なる半透明レイヤー、UI とは独立。 */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background: radial-gradient(
      ellipse at 30% center,
      rgba(0, 0, 0, 0.4) 0%,
      transparent 70%
    );
  }

  /* Font Set C Hero H1 — 縦 3 段詰み、左寄せ、opsz=144 で巨大化。 */
  .hero__title--vertical {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(4rem, 3rem + 8vw, 10rem);
    font-weight: 600;
    line-height: 0.9;
    letter-spacing: -0.03em;
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    text-shadow: var(--text-shadow-onbrew);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }

  .hero__word {
    display: block;
  }

  .hero__statement {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    color: var(--fg);
    /* Statement は opsz を一段小さくして表情を変える。 */
    font-variation-settings: 'opsz' 100, 'SOFT' 30;
    text-shadow: var(--text-shadow-onbrew);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) 120ms both;
  }

  .hero__sub {
    font-size: var(--fs-base);
    font-weight: 400;
    line-height: 1.5;
    margin-block-start: var(--space-lg);
    margin-block-end: 0;
    margin-inline: 0;
    color: var(--muted);
    max-width: 42rem; /* en は欧文密度低、ja の 32rem とは別値 */
    /* Slightly stronger shadow on the muted subtitle. */
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.5);
    animation: hero-fade 720ms cubic-bezier(0.2, 0.7, 0.2, 1) 240ms both;
  }

  .hero__cue {
    position: absolute;
    left: 50%;
    bottom: var(--space-lg);
    transform: translateX(-50%);
    color: var(--muted);
    font-size: var(--fs-lg);
    line-height: 1;
    text-decoration: none;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: var(--radius-chip);
    background: rgba(11, 11, 11, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: color 120ms ease;
    animation: cue-bob 2400ms ease-in-out infinite;
  }

  .hero__cue:hover,
  .hero__cue:focus-visible {
    color: var(--fg);
  }

  /* Full-width Brew overlay bands — see ja/index.astro for rationale. */
  .section-band {
    width: 100%;
  }
  /* 2026-05-28: overlay 階段が「区切り線」として見える指摘を受けて
     段差を解消、全セクション透明化。文字可読性は text-shadow 側で確保 */
  .section-band--soft,
  .section-band--strong {
    background: transparent;
  }

  @supports not (backdrop-filter: blur(6px)) {
    .hero__cue {
      background: rgba(11, 11, 11, 0.6);
    }
  }

  .works-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .works-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .about__body {
    color: var(--fg);
    font-size: var(--fs-base);
    line-height: var(--lh-normal);
    max-width: 42rem;
    margin: 0 0 var(--space-md);
  }

  .about__placeholder {
    display: inline-block;
    color: var(--muted);
    font-size: var(--fs-sm);
    border-bottom: 1px dashed var(--rule);
    padding-bottom: 2px;
  }

  @media (min-width: 640px) {
    .hero {
      padding: var(--space-3xl) var(--space-xl);
      gap: var(--space-lg);
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: var(--space-3xl) var(--space-2xl);
    }
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes cue-bob {
    0%, 100% { transform: translate(-50%, 0); }
    50%      { transform: translate(-50%, 0.3rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__title,
    .hero__title--vertical,
    .hero__statement,
    .hero__sub,
    .hero__cue {
      animation: none;
    }
  }
</style>
