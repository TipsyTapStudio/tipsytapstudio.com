---
// ProductCard — one entry in the Works grid.
//
// Inputs:
//   - slug: stable identifier → looked up against i18n keys
//     (`hub_works_item_${slug}_title` / `_desc`)
//   - status / tags / urls: read straight from apps/hub/src/data/works.json
//
// The card is purely structural — visual lift on hover is the only motion,
// and it self-disables under prefers-reduced-motion. JS-zero by design.
//
// Layout: a horizontal row (media left, body right) at >=640px; stacks
// vertically on mobile. `size` drives a 'large' vs 'small' variant — only
// SPV-2 is large today (see works.json). Large = bigger media + larger title +
// more desc lines + tags shown. Small = compact media + 2-line desc + no tags.

import { t, type Locale } from '@ttsui/i18n';
import TagChip from './TagChip.astro';

type Status = 'live' | 'beta' | 'tinkering' | 'sketch';
type Size = 'large' | 'small';

interface Props {
  slug: string;
  status: Status;
  size?: Size;
  tags: string[];
  thumb: string | null;
  demoUrl: string | null;
  repoUrl: string | null;
  lpUrl: string | null;
  locale: Locale;
}

// `status` is accepted for prop-contract parity (index passes work.status, and
// it still drives sortWorks ordering) but is no longer rendered — the status
// badge was dropped 2026-06-07. Intentionally not destructured here.
const { slug, size = 'small', tags, thumb, demoUrl, repoUrl, lpUrl, locale } = Astro.props;

// Tags only render on large cards — small cards keep status (via badge) but
// drop tag chips to avoid density overload in the compact row.
const showTags = size === 'large' && tags.length > 0;

const title = t(`hub_works_item_${slug}_title`, locale);
const desc = t(`hub_works_item_${slug}_desc`, locale);
const repoLabel = t('hub_works_cta_repo', locale);

// If an LP is set, the title links there; otherwise the card stays inert.
const titleHref = lpUrl ?? demoUrl ?? repoUrl ?? null;

// Media (icon) click target: SPV-2 → its LP, everything else → the GitHub
// Pages demo (or LINE store for the stickers). lpUrl is null on all but SPV-2,
// so `lpUrl ?? demoUrl` resolves correctly per item. Falls back to a plain
// div (no link) when neither URL exists.
const mediaHref = lpUrl ?? demoUrl ?? null;
---

<article class:list={['card', `card--${size}`]} aria-labelledby={`card-${slug}-title`}>
  {mediaHref ? (
    /* Media is a big mouse target that duplicates the title link's
       destination. It's hidden from SR + Tab (aria-hidden + tabindex=-1) so
       keyboard/SR users hit the title link once instead of two identical
       links (designer a11y note). Safe because every card's media and title
       resolve to the same href in current data. */
    <a
      class={`card__media${thumb ? ' card__media--has-image' : ''}`}
      href={mediaHref}
      target="_blank"
      rel="noopener noreferrer"
      tabindex="-1"
      aria-hidden="true"
    >
      {thumb ? (
        <img src={thumb} alt="" loading="lazy" decoding="async" />
      ) : (
        <span class="card__placeholder" aria-hidden="true">T</span>
      )}
    </a>
  ) : (
    <div class={`card__media${thumb ? ' card__media--has-image' : ''}`} aria-hidden={thumb ? undefined : 'true'}>
      {thumb ? (
        <img src={thumb} alt={title} loading="lazy" decoding="async" />
      ) : (
        <span class="card__placeholder">T</span>
      )}
    </div>
  )}

  <div class="card__body">
    <header class="card__header">
      <h4 id={`card-${slug}-title`} class="card__title">
        {titleHref ? (
          titleHref.startsWith('http') ? (
            <a href={titleHref} target="_blank" rel="noopener noreferrer">{title}</a>
          ) : (
            <a href={titleHref}>{title}</a>
          )
        ) : (
          title
        )}
      </h4>
    </header>

    <p class="card__desc">{desc}</p>

    {showTags && (
      <ul class="card__tags" role="list" aria-label="Tags">
        {tags.map((tag) => (
          <li><TagChip label={tag} /></li>
        ))}
      </ul>
    )}

    {repoUrl && (
      <nav class="card__ctas" aria-label={`${title} links`}>
        <a class="card__cta" href={repoUrl} target="_blank" rel="noopener noreferrer">{repoLabel}</a>
      </nav>
    )}
  </div>
</article>

<style>
  .card {
    /* Mobile-first: stacked (media on top, body below). At >=640px this flips
       to a horizontal row (see media query). */
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
    /* Brew background sits behind: half-opaque warm card + warm hairline +
       backdrop blur so the card reads as a distinct surface against any
       beer palette. .card__media stays opaque (--card-media-bg) so thumbnails
       are not desaturated by the underlying gradient. */
    border: 1px solid var(--card-border-onbrew);
    border-radius: var(--radius-card);
    background: var(--card-bg-onbrew);
    /* blur は 8px 維持 (designer Must): これ以上上げると Brew が潰れて
       「透ける」意図が薄れる。bg α を 0.66 に上げたので 8px で背景可読性は十分。 */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    /* elevation: 影ゼロだと動く Brew にカードが沈む。暖色寄りの二段影 (token) で接地。 */
    box-shadow: var(--shadow-card);
    transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
    height: 100%;
  }

  /* --- Horizontal row layout (tablet/desktop) ---
     Media pinned left at a fixed square; body fills the rest. Card height
     follows content. Large variant gets a wider media well + min-height. */
  @media (min-width: 640px) {
    .card {
      flex-direction: row;
      align-items: stretch;
      gap: var(--space-md);
    }
    .card--small {
      min-height: 8rem;
    }
    .card--large {
      min-height: 13rem;
    }
    .card__media {
      flex: 0 0 8rem;
      align-self: center;
    }
    .card--large .card__media {
      flex-basis: 16rem;
    }
  }

  /* Body wraps everything to the right of the media. Column flex so the CTA
     row can pin to the bottom (margin-top:auto) now that .card itself is a
     row at >=640px. */
  .card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
    min-width: 0;
  }

  /* backdrop-filter fallback — bump opacity so the card stays legible on
     browsers that don't composite the blur layer. */
  @supports not (backdrop-filter: blur(8px)) {
    .card {
      /* blur 非対応環境では Brew 透けが汚れるので暖色寄せ + 不透明度を .82 まで上げる
         (designer N3)。 */
      background: rgba(20, 16, 8, 0.82);
    }
  }

  .card:hover {
    /* hover の border を --fg (暖白) に。--muted は明部 Brew で縁が弱く溶ける
       (designer S4)。影も hover token に拡張し translateY と物理一致 (S2)。 */
    border-color: var(--fg);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .card:focus-within {
    border-color: var(--fg);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
    outline: 2px solid var(--fg);
    outline-offset: 4px;
  }

  .card__media {
    /* Mobile: a wide banner; desktop row: a fixed square (set in the media
       query above via flex-basis). Large gets a slightly taller mobile banner
       so the size hierarchy survives the stacked layout. */
    aspect-ratio: 16 / 9;
    width: 100%;
    overflow: hidden;
    /* 純グレー → 暖暗褐。サムネ台座をカード bg と同族にし、アイコン透過部が
       灰色から暖色へ (designer M3)。 */
    background: var(--card-media-bg, #16120a);
    border-radius: calc(var(--radius-card) - 2px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card--large .card__media {
    aspect-ratio: 4 / 3;
  }

  @media (min-width: 640px) {
    /* In the desktop row, media is a fixed-width square regardless of variant
       banner ratios above. */
    .card__media,
    .card--large .card__media {
      aspect-ratio: 1 / 1;
      width: auto;
    }
  }

  /* media-as-link: cursor + focus ring only; the card-wide lift is handled by
     .card:focus-within. A subtle img dim on hover signals interactivity
     without competing with the warm-tone elevation. */
  a.card__media {
    cursor: pointer;
    text-decoration: none;
  }

  a.card__media:focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: 2px;
  }

  a.card__media:hover img {
    opacity: 0.85;
    transform: scale(1.03);
  }

  /* "T" placeholder (LINE Stamps, no thumb): lift its base opacity when it's a
     link so it reads as a target, and react on hover like the img does. */
  a.card__media .card__placeholder {
    opacity: 0.55;
  }

  a.card__media:hover .card__placeholder {
    opacity: 0.8;
  }

  .card__media--has-image {
    padding: var(--space-md);
  }

  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .card__placeholder {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 1.5rem + 3vw, 3.5rem);
    font-weight: 500;
    color: var(--muted);
    opacity: 0.4;
    letter-spacing: 0;
    user-select: none;
  }

  /* badge dropped 2026-06-07 — header is now the title alone. */
  .card__header {
    margin: 0;
  }

  .card__title {
    margin: 0;
    font-size: var(--fs-lg);
    font-weight: 500;
    line-height: var(--lh-tight);
    color: var(--fg);
  }

  /* Large card: bump the title up for hero emphasis — but NOT to --fs-xl,
     which is the same token as the section H2 ("Works") and would make the
     card title compete with the page heading (designer Must). Sit it between
     --fs-lg (22px) and --fs-xl (60px): ~40px at desktop, ~1.8x the small card. */
  .card--large .card__title {
    font-size: clamp(1.75rem, 1.4rem + 1.4vw, 2.5rem);
  }

  .card__title a {
    color: inherit;
    text-decoration: none;
  }

  .card__title a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .card__desc {
    margin: 0;
    color: var(--muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
  }

  /* Desc line-clamp keeps rows even. Small = 2 lines (compact), large = 4.
     Clamp only trims line count; color/size/background are untouched so the
     desc AA contrast (4.88:1 over the brightest Brew) is preserved. */
  .card--small .card__desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* 広い本文(desktop で ~550px)だと小カードの desc が「横長の帯」に間延び
       するので読み幅を絞る。title 行/CTA は全幅維持で右端を揃える (designer S)。 */
    max-width: 34rem;
  }

  .card--large .card__desc {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .card__ctas {
    display: flex;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-xs);
  }

  .card__cta {
    color: var(--fg);
    font-size: var(--fs-sm);
    text-decoration: none;
    border-bottom: 1px solid var(--border-hairline);
    padding-bottom: 2px;
    transition: border-color 120ms ease, color 120ms ease;
  }

  .card__cta:hover,
  .card__cta:focus-visible {
    border-color: var(--fg);
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .card:hover,
    .card:focus-within {
      transform: none;
      transition: none;
    }
    /* reduced 時は影の瞬間変化を避け、resting elevation に固定 (designer 注4)。
       focus-within の outline は a11y 上残す。 */
    .card:hover,
    .card:focus-within {
      box-shadow: var(--shadow-card);
    }
    /* media img の hover scale/transition も reduced 時は無効化 */
    .card__media img,
    a.card__media:hover img {
      transform: none;
      transition: none;
    }
  }
</style>
