---
// ManifestoArrow — one beat of the studio manifesto.
//
// Layout: a large arrow glyph on the left, keyword + body stacked on the right.
// The arrow is ASCII "→" with `font-variant-emoji: text` as a guard against
// platforms that would otherwise auto-emojify it (some Android stacks).
// Decorative — aria-hidden so SR users only hear keyword + body.

interface Props {
  keyword: string;
  body: string;
}

const { keyword, body } = Astro.props;
---

<div class="manifesto__beat">
  <span class="manifesto__arrow" aria-hidden="true">→</span>
  <p class="manifesto__keyword">{keyword}</p>
  <p class="manifesto__body">{body}</p>
</div>

<style>
  .manifesto__beat {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-sm) var(--space-md);
    align-items: baseline;
  }

  .manifesto__arrow {
    font-size: var(--fs-3xl);
    color: var(--muted);
    line-height: 1;
    grid-row: 1 / 3;
    align-self: start;
    /* Some Android stacks auto-emojify "→" with color glyphs. Force text style. */
    font-variant-emoji: text;
  }

  .manifesto__keyword {
    font-size: var(--fs-3xl);
    font-weight: 500;
    line-height: var(--lh-tight);
    letter-spacing: var(--track-display);
    grid-column: 2;
    margin: 0;
  }

  /* JP: 0.12em on kana spreads keywords into broken-up shapes; tighten back. */
  .manifesto__keyword:lang(ja) {
    letter-spacing: 0;
  }

  .manifesto__body {
    font-size: var(--fs-lg);
    color: var(--muted);
    line-height: var(--lh-normal);
    grid-column: 2;
    max-width: 38rem;
    margin: 0;
  }
</style>
