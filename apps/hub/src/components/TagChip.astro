---
// TagChip — inline meta chip for product tags (e.g. #extension, #gadget).
//
// The "#" prefix is rendered here (not in data) so the data file keeps clean
// tag tokens (`extension`, `gadget`, …) usable for filtering down the road.

interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="chip">#{label}</span>

<style>
  .chip {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: transparent;
    color: var(--muted);
    font-size: var(--fs-xs);
    border: 1px solid var(--rule);
    line-height: 1.2;
  }
</style>
