---
// BrewCanvas — Lab #002 ("Brewing"). Raw WebGL2 fragment shader.
//
// v2 (3-beer cycle):
//   - Bubble layer removed (was: sparse vertical streaks; u_bubble uniform).
//   - Static ±8°/120s hue drift removed.
//   - colA / colB now cycle through 3 designer-confirmed beer palettes in
//     OKLCH space, CPU-side, with a 720s wall-clock period and a 75/25
//     dwell/transition split per beer (smoothstep-eased transition).
//
//   Beer palettes (designer-confirmed):
//     pilsner — colA #0F0C05  colB #92711B
//     wit     — colA #0F0E0A  colB #7C6F49
//     ipa     — colA #0E0905  colB #6E4A1E   (the v1 palette, kept as the 3rd slot)
//
// Sliders bound (via `paramchange` events bubbled from the parent
// ExperimentFrame): speed, intensity. (Bubble slider removed in v2.)
//
// Captions: when currentIndex flips, dispatches a `brewbeerchange` event up to
// `.experiment-frame` carrying `{ name: 'pilsner' | 'wit' | 'ipa' }` so the
// caption strip (rendered by the parent page) can update without coupling
// DOM. Updated only on index change, not every frame.
//
// Performance discipline matches FluxCanvas:
// - devicePixelRatio clamped to <= 1.5
// - IntersectionObserver pauses the rAF when off-screen
// - context-lost stops the loop; the CSS fallback under the canvas stays visible
// - prefers-reduced-motion: one frame at u_time = 0 using the current
//   wall-clock beer mix, no rAF

const fallbackId = 'brew-fallback';
---

<div class="brew-canvas" role="presentation" aria-hidden="true" data-canvas="brew">
  {/* Always-visible fallback. Sits under the canvas; remains the only visible
      layer if WebGL fails to init or the context is lost. */}
  <div class={`brew-canvas__fallback ${fallbackId}`}></div>
  <canvas class="brew-canvas__gl" aria-hidden="true"></canvas>
</div>

<style>
  .brew-canvas {
    position: absolute;
    inset: 0;
  }
  .brew-canvas__fallback {
    position: absolute;
    inset: 0;
    /* Matches the IPA palette colA → colB (the v1 default), so a WebGL-less
       client sees the same warmth as a mid-cycle visitor. */
    background: linear-gradient(180deg, #0e0905 0%, #6e4a1e 100%);
  }
  .brew-canvas__gl {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  // Wire each BrewCanvas instance separately so multiple Lab pages would
  // continue to work without coupling.
  const nodes = document.querySelectorAll<HTMLElement>('.brew-canvas');

  const VERT = `#version 300 es
in vec2 a_pos;
void main() { gl_Position = vec4(a_pos, 0.0, 1.0); }`;

  // Brew v2 = same Flux base field; colour identity comes from the cycling
  // colA / colB uniforms (CPU-driven OKLCH lerp). No bubble layer.
  const FRAG = `#version 300 es
precision highp float;
out vec4 outColor;
uniform vec2 u_resolution;
uniform float u_time;
uniform float u_intensity;
uniform vec3 u_colA;
uniform vec3 u_colB;

float hash(vec2 p) {
  p = fract(p * vec2(123.34, 456.21));
  p += dot(p, p + 45.32);
  return fract(p.x * p.y);
}

float noise(vec2 p) {
  vec2 i = floor(p);
  vec2 f = fract(p);
  float a = hash(i);
  float b = hash(i + vec2(1.0, 0.0));
  float c = hash(i + vec2(0.0, 1.0));
  float d = hash(i + vec2(1.0, 1.0));
  vec2 u = f * f * (3.0 - 2.0 * f);
  return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
}

float fbm(vec2 p) {
  float v = 0.0;
  float amp = 0.5;
  for (int i = 0; i < 4; i++) {
    v += amp * noise(p);
    p *= 2.0;
    amp *= 0.5;
  }
  return v;
}

void main() {
  vec2 uv = gl_FragCoord.xy / u_resolution.xy;
  vec2 p = uv * 2.5;
  float n1 = fbm(p + vec2(u_time, u_time * 0.7));
  float n2 = fbm(p * 1.6 - vec2(u_time * 0.4, u_time));
  float n = mix(n1, n2, 0.5);

  n = 0.5 + (n - 0.5) * (0.5 + u_intensity * 1.2);

  float k = pow(clamp(n, 0.0, 1.0), 2.2);
  vec3 color = mix(u_colA, u_colB, k);

  outColor = vec4(color, 1.0);
}`;

  // --- Color helpers (sRGB ↔ linear ↔ OKLab/OKLCH) for CPU-side palette
  // interpolation. OKLCH keeps perceptual lightness during mid-transition so
  // the in-between pilsner→wit slot doesn't briefly mud out the way naive
  // sRGB lerps do.
  type RGB = [number, number, number]; // sRGB 0..1

  const hexToRgb = (hex: string): RGB => {
    const h = hex.replace('#', '');
    return [
      parseInt(h.slice(0, 2), 16) / 255,
      parseInt(h.slice(2, 4), 16) / 255,
      parseInt(h.slice(4, 6), 16) / 255,
    ];
  };

  // sRGB nonlinear → linear (per channel).
  const srgbToLinear = (c: number): number =>
    c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);

  // linear → sRGB nonlinear (per channel).
  const linearToSrgb = (c: number): number =>
    c <= 0.0031308 ? 12.92 * c : 1.055 * Math.pow(c, 1 / 2.4) - 0.055;

  // Linear sRGB → OKLab (Björn Ottosson).
  const linToOklab = ([r, g, b]: RGB): [number, number, number] => {
    const l = 0.4122214708 * r + 0.5363325363 * g + 0.0514459929 * b;
    const m = 0.2119034982 * r + 0.6806995451 * g + 0.1073969566 * b;
    const s = 0.0883024619 * r + 0.2817188376 * g + 0.6299787005 * b;
    const l_ = Math.cbrt(l);
    const m_ = Math.cbrt(m);
    const s_ = Math.cbrt(s);
    return [
      0.2104542553 * l_ + 0.793617785 * m_ - 0.0040720468 * s_,
      1.9779984951 * l_ - 2.428592205 * m_ + 0.4505937099 * s_,
      0.0259040371 * l_ + 0.7827717662 * m_ - 0.808675766 * s_,
    ];
  };

  // OKLab → linear sRGB.
  const oklabToLin = ([L, a, b]: [number, number, number]): RGB => {
    const l_ = L + 0.3963377774 * a + 0.2158037573 * b;
    const m_ = L - 0.1055613458 * a - 0.0638541728 * b;
    const s_ = L - 0.0894841775 * a - 1.291485548 * b;
    const l = l_ * l_ * l_;
    const m = m_ * m_ * m_;
    const s = s_ * s_ * s_;
    return [
      4.0767416621 * l - 3.3077115913 * m + 0.2309699292 * s,
      -1.2684380046 * l + 2.6097574011 * m - 0.3413193965 * s,
      -0.0041960863 * l - 0.7034186147 * m + 1.707614701 * s,
    ];
  };

  // sRGB hex → OKLab.
  const hexToOklab = (hex: string): [number, number, number] => {
    const [r, g, b] = hexToRgb(hex);
    return linToOklab([srgbToLinear(r), srgbToLinear(g), srgbToLinear(b)]);
  };

  // OKLab lerp (component-wise; OK in OKLab since hue/chroma are encoded as
  // a,b coords and a straight lerp matches the OKLCH=='oklch' interp the
  // tokens declare for the typical case where adjacent palettes share hue
  // family).
  const lerpOklab = (
    A: [number, number, number],
    B: [number, number, number],
    t: number,
  ): [number, number, number] => [
    A[0] + (B[0] - A[0]) * t,
    A[1] + (B[1] - A[1]) * t,
    A[2] + (B[2] - A[2]) * t,
  ];

  // OKLab → sRGB float triplet, clamped to gamut.
  const oklabToRgb = (lab: [number, number, number]): RGB => {
    const [lr, lg, lb] = oklabToLin(lab);
    const r = linearToSrgb(Math.max(0, Math.min(1, lr)));
    const g = linearToSrgb(Math.max(0, Math.min(1, lg)));
    const b = linearToSrgb(Math.max(0, Math.min(1, lb)));
    return [r, g, b];
  };

  // Designer-confirmed 3-beer cycle, in the order tokens.lab.brew.cycle.
  const BEERS = [
    { name: 'pilsner', colA: '#0F0C05', colB: '#92711B' },
    { name: 'wit',     colA: '#0F0E0A', colB: '#7C6F49' },
    { name: 'ipa',     colA: '#0E0905', colB: '#6E4A1E' },
  ] as const;
  const N_BEERS = BEERS.length;
  const CYCLE_PERIOD_MS = 720_000; // 12 minutes
  const DWELL_RATIO = 0.75;

  // Pre-compute each palette in OKLab once.
  const BEER_LAB = BEERS.map((b) => ({
    name: b.name,
    A: hexToOklab(b.colA),
    B: hexToOklab(b.colB),
  }));

  // smoothstep(0, 1, x) for x already normalised to 0..1.
  const smooth = (x: number): number => {
    const t = Math.max(0, Math.min(1, x));
    return t * t * (3 - 2 * t);
  };

  function initOne(host: HTMLElement) {
    const canvas = host.querySelector<HTMLCanvasElement>('.brew-canvas__gl');
    if (!canvas) return;
    const gl = canvas.getContext('webgl2', { antialias: false, powerPreference: 'low-power' });
    if (!gl) {
      canvas.remove(); // fallback gradient stays visible
      return;
    }

    const compile = (type: number, src: string): WebGLShader | null => {
      const sh = gl.createShader(type);
      if (!sh) return null;
      gl.shaderSource(sh, src);
      gl.compileShader(sh);
      if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS)) {
        // eslint-disable-next-line no-console
        console.warn('[BrewCanvas] shader compile failed', gl.getShaderInfoLog(sh));
        return null;
      }
      return sh;
    };

    const vs = compile(gl.VERTEX_SHADER, VERT);
    const fs = compile(gl.FRAGMENT_SHADER, FRAG);
    if (!vs || !fs) { canvas.remove(); return; }

    const prog = gl.createProgram()!;
    gl.attachShader(prog, vs);
    gl.attachShader(prog, fs);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) { canvas.remove(); return; }
    gl.useProgram(prog);

    // Full-screen triangle.
    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
    const loc = gl.getAttribLocation(prog, 'a_pos');
    gl.enableVertexAttribArray(loc);
    gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

    const uTime = gl.getUniformLocation(prog, 'u_time');
    const uRes = gl.getUniformLocation(prog, 'u_resolution');
    const uIntensity = gl.getUniformLocation(prog, 'u_intensity');
    const uColA = gl.getUniformLocation(prog, 'u_colA');
    const uColB = gl.getUniformLocation(prog, 'u_colB');

    const frame = host.closest('.experiment-frame');

    const state = {
      speed: 0.3,
      intensity: 0.4,
      time: 0,
      visible: false,
      raf: 0,
      reduced: false,
      lastBeerIndex: -1,
    };

    const mql = window.matchMedia('(prefers-reduced-motion: reduce)');
    state.reduced = mql.matches;
    mql.addEventListener?.('change', (e) => { state.reduced = e.matches; if (state.reduced) drawOnce(); });

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      const w = Math.floor(canvas!.clientWidth * dpr);
      const h = Math.floor(canvas!.clientHeight * dpr);
      if (canvas!.width !== w || canvas!.height !== h) {
        canvas!.width = w;
        canvas!.height = h;
        gl!.viewport(0, 0, w, h);
      }
    }

    // Compute current cycle state from wall-clock; upload uColA/uColB; fire
    // brewbeerchange when currentIndex flips.
    function uploadColors() {
      const nowMs = Date.now();
      // phase in 0..N_BEERS, advances 3 slots per CYCLE_PERIOD_MS.
      const phase = ((nowMs / CYCLE_PERIOD_MS) * N_BEERS) % N_BEERS;
      const currentIndex = Math.floor(phase);
      const nextIndex = (currentIndex + 1) % N_BEERS;
      const t = phase - currentIndex; // 0..1 within current slot

      // 0..DWELL_RATIO: hold current; DWELL_RATIO..1: smoothstep into next.
      const w = t < DWELL_RATIO
        ? 0
        : smooth((t - DWELL_RATIO) / (1 - DWELL_RATIO));

      const cur = BEER_LAB[currentIndex];
      const nxt = BEER_LAB[nextIndex];
      const A = oklabToRgb(lerpOklab(cur.A, nxt.A, w));
      const B = oklabToRgb(lerpOklab(cur.B, nxt.B, w));
      gl!.uniform3f(uColA, A[0], A[1], A[2]);
      gl!.uniform3f(uColB, B[0], B[1], B[2]);

      if (currentIndex !== state.lastBeerIndex) {
        state.lastBeerIndex = currentIndex;
        frame?.dispatchEvent(
          new CustomEvent('brewbeerchange', {
            detail: { name: BEERS[currentIndex].name, index: currentIndex },
            bubbles: false,
          }),
        );
      }
    }

    function draw() {
      resize();
      gl!.uniform1f(uTime, state.time);
      gl!.uniform2f(uRes, canvas!.width, canvas!.height);
      gl!.uniform1f(uIntensity, state.intensity);
      uploadColors();
      gl!.drawArrays(gl!.TRIANGLES, 0, 3);
    }

    function drawOnce() {
      // reduced-motion: render the current wall-clock beer mix at u_time = 0
      // so the still frame reflects whatever beer is "now brewing".
      state.time = 0;
      draw();
    }

    function tick() {
      state.time += 0.0008 + state.speed * 0.012;
      draw();
      state.raf = requestAnimationFrame(tick);
    }

    function start() {
      if (state.raf || state.reduced) { drawOnce(); return; }
      state.raf = requestAnimationFrame(tick);
    }
    function stop() {
      if (state.raf) { cancelAnimationFrame(state.raf); state.raf = 0; }
    }

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            state.visible = e.isIntersecting;
            if (state.visible) start(); else stop();
          }
        },
        { threshold: 0.05 },
      );
      io.observe(host);
    } else {
      start();
    }

    window.addEventListener('resize', () => { if (state.visible) draw(); });

    // Context loss: stop rAF; the CSS fallback under the <canvas> stays visible.
    canvas.addEventListener('webglcontextlost', (e) => { e.preventDefault(); stop(); });

    frame?.addEventListener('paramchange', (event) => {
      const { name, value } = (event as CustomEvent<{ name: string; value: number }>).detail;
      if (name === 'speed') state.speed = value;
      else if (name === 'intensity') state.intensity = value;
      if (state.reduced) drawOnce();
    });

    // First paint.
    drawOnce();
  }

  nodes.forEach(initOne);
</script>
</content>
</invoke>