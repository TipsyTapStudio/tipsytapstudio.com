---
// DriftCanvas — Lab #001 A. Pure-CSS conic-gradient backdrop.
//
// Honest baseline: zero JS rendering, no <canvas>, no SVG noise. Speed and
// Intensity are CSS custom properties (--drift-speed, --drift-intensity) that
// the page-level slider listener rewrites on the .drift-canvas element.
//
// Speed mapping  (slider 0→1) : 30s → 4s per cycle. Default 0.35 (~10s).
// Intensity mapping (0→1)    : interpolate from flat #1A1A1A to the full
//                              4-stop ramp. Default 0.5.
// Reduce-motion              : animation paused; static snapshot at intensity 0.5.
---

<div
  class="drift-canvas"
  role="presentation"
  aria-hidden="true"
  data-canvas="drift"
  style="--drift-speed: 0.35; --drift-intensity: 0.5;"
></div>

<style>
  .drift-canvas {
    position: absolute;
    inset: 0;

    /* Map slider 0..1 to animation duration via a piecewise calc.
       30s at 0 → 4s at 1 → duration = (30 - 26 * speed)s. */
    --drift-cycle: calc((30 - 26 * var(--drift-speed)) * 1s);

    /* Intensity interpolation:
       at 0 → all stops collapse toward --lab-shade-1 (#1A1A1A) — nearly flat.
       at 1 → full ramp #0B → #1A → #26 → #3A.
       We blend with color-mix() per stop. */
    --c0: color-mix(in oklab, var(--lab-shade-1) calc((1 - var(--drift-intensity)) * 100%), var(--bg));
    --c1: var(--lab-shade-1);
    --c2: color-mix(in oklab, var(--lab-shade-1) calc((1 - var(--drift-intensity)) * 100%), var(--lab-shade-2));
    --c3: color-mix(in oklab, var(--lab-shade-1) calc((1 - var(--drift-intensity)) * 100%), #3A3A3A);

    background:
      conic-gradient(
        from 0deg at 60% 40%,
        var(--c0) 0deg,
        var(--c1) 90deg,
        var(--c2) 180deg,
        var(--c3) 270deg,
        var(--c0) 360deg
      );
    will-change: transform;
    animation: drift-rotate var(--drift-cycle) var(--ease-flux) infinite;
    transform-origin: 60% 40%;
  }

  @keyframes drift-rotate {
    from { transform: rotate(0deg) scale(1.5); }
    to   { transform: rotate(360deg) scale(1.5); }
  }

  @media (prefers-reduced-motion: reduce) {
    .drift-canvas {
      animation: none;
      /* Force a calm midpoint snapshot. */
      --drift-intensity: 0.5;
    }
  }
</style>

<script>
  // Translate `paramchange` events on the parent .experiment-frame into
  // CSS variable writes on this DriftCanvas instance. Tiny: < 0.5KB.
  const nodes = document.querySelectorAll<HTMLElement>('.drift-canvas');
  nodes.forEach((node) => {
    const frame = node.closest('.experiment-frame');
    if (!frame) return;
    frame.addEventListener('paramchange', (event) => {
      const { name, value } = (event as CustomEvent<{ name: string; value: number }>).detail;
      if (name === 'speed') {
        node.style.setProperty('--drift-speed', value.toString());
      } else if (name === 'intensity') {
        node.style.setProperty('--drift-intensity', value.toString());
      }
    });
  });
</script>
