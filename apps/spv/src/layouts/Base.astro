---
// SPV-2 LP base layout — global <html>/<head>/<body> shell.
//
// Separate design system from the hub (tipsytapstudio.com):
// - Hub = warm Brew background + Fraunces serif (monochrome UI).
// - SPV-2 = deep-black instrument console + neon accents (color unlocked).
//   Fonts: Space Grotesk (display/body) + JetBrains Mono (instrument numerals).
//   Per CLAUDE.md 2026-06-07: typography follows each product's world, not a
//   single shared family. The series bond is the spacing/layout scale + the
//   parent color hierarchy, not the typeface.
//
// JS-zero by default. Motion is CSS @keyframes only and self-disables under
// prefers-reduced-motion. The only client JS on this LP is (1) the YouTube
// facade click handler and (2) an IntersectionObserver that pauses offscreen
// instrument animations — both progressive enhancements.

import { type Locale } from '@ttsui/i18n';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Self-hosted variable fonts via @fontsource (same-origin, no third-party
// requests — consistent with SPV-2's "zero network" story).
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;

const siteTitle = title ?? 'SPV-2 — Side Panel Visualizer';
const siteDescription =
  description ??
  'Studio-grade audio meters in your browser side panel — oscilloscope, spectrum, chromagram, BPM and key detection. A Tipsy Tap Studio extension.';

// English-only for now (2026-06-07) — no locale switcher.
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png" />
    <link rel="apple-touch-icon" sizes="128x128" href="/icon-128.png" />
    {/* Self-hosted fonts (imported in frontmatter) — no external font requests. */}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <Header locale={locale} />

    <main id="main">
      <slot />
    </main>

    <Footer locale={locale} />
  </body>
</html>

<style is:global>
  /* ===== SPV-2 design tokens (instrument console / neon) =====
     Separate system from the hub. WCAG contrast computed against the darkest
     background (#0A0A0A). Where a neon hue is used for TEXT it uses the
     "readable" variant; the saturated "vivid" variant is for strokes/glow/fill
     only (avoids halation + AA failures on the dark field). */
  :root {
    /* --- Background / surface / structure --- */
    --bg: #0a0a0a;          /* page backmost — the bezel's outside */
    --bg-1: #101013;        /* section band / card surface (+1) */
    --bg-2: #16161b;        /* instrument screen / nested panel (+2) */
    --grid: #1e1e24;        /* instrument grid lines / hairlines */
    --grid-strong: #262630; /* instrument main axis */
    --border: rgba(255, 255, 255, 0.10);
    --border-hover: rgba(255, 255, 255, 0.18);

    /* --- Text --- */
    --fg: #f2f3f5;          /* headings/body — cool white, 18.6:1 */
    --muted: #a7acb5;       /* body support / lede / caption — 7.1:1 AA */
    --muted-2: #7e838c;     /* weakest meta: dates, version, notes — 4.6:1 */
    --fg-on-accent: #06080a; /* text on a neon fill (CTA) */

    /* --- Module accent = 5 meters (information color, not decoration) ---
       readable (text) / vivid (stroke·glow·fill) split. */
    --osc: #3de8ff;            --osc-vivid: #00ffff;       /* Oscilloscope */
    --spec-lo: #ff4fc3;        --spec-hi: #9b6bff;          /* Spectrum lo→hi */
    --spec-grad: linear-gradient(90deg, #ff2ea6, #7c5cff);
    --chroma: #ffb14e;         --chroma-vivid: #ff9500;     /* Chromagram */
    --bpm: #4ade80;            --bpm-vivid: #00ff88;        /* BPM */
    --key: #c9a6ff;            --key-vivid: #b388ff;        /* Key */
    --data: #4ade80;           /* Track Info / readout = terminal green */

    /* --- System --- */
    --peak: #ffffff;           /* peak-hold line / top highlight */
    --warn: #ff5a5a;           /* warning text (AA) */
    --warn-vivid: #ff3333;     /* warning fill/dot only */

    /* --- CTA (one fixed color, role-separated from instrument hues) --- */
    --cta-bg: #00ff88;
    --cta-bg-hover: #33ffa1;
    --cta-fg: #06080a;
    --cta-ghost-border: rgba(0, 255, 136, 0.5);
    --cta-ghost-fg: #4ade80;
    --focus-ring: #3de8ff;

    /* --- Glow (decorative; outline only, never on glyph bodies) --- */
    --glow-osc: 0 0 12px rgba(0, 255, 255, 0.45);
    --glow-spec: 0 0 12px rgba(155, 107, 255, 0.40);
    --glow-data: 0 0 10px rgba(0, 255, 136, 0.40);
    --glow-cta: 0 0 24px rgba(0, 255, 136, 0.35);

    /* --- Fonts --- */
    --font-display: 'Space Grotesk Variable', 'Space Grotesk', system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-body: var(--font-display);
    --font-mono: 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;

    /* --- Scale: inherit the hub's spacing/fs/radius scale for series rhythm --- */
    --space-3xs: 0.25rem;
    --space-2xs: 0.5rem;
    --space-xs: 0.75rem;
    --space-sm: 1rem;
    --space-md: 1.5rem;
    --space-lg: 2rem;
    --space-xl: 3rem;
    --space-2xl: 4.5rem;
    --space-3xl: 6rem;
    --space-section: clamp(4.5rem, 3rem + 6vw, 8rem);

    --fs-xs: clamp(0.75rem, 0.72rem + 0.15vw, 0.8125rem);
    --fs-sm: clamp(0.875rem, 0.84rem + 0.18vw, 0.95rem);
    --fs-base: clamp(1rem, 0.96rem + 0.2vw, 1.125rem);
    --fs-lg: clamp(1.125rem, 1.05rem + 0.4vw, 1.375rem);
    --fs-xl: clamp(2rem, 1.4rem + 3vw, 3.75rem);
    --fs-2xl: clamp(2.5rem, 1.6rem + 4.5vw, 5rem);
    --fs-3xl: clamp(3rem, 2rem + 5vw, 6rem);

    --lh-tight: 1.15;
    --lh-normal: 1.6;
    --track-display: -0.03em;
    --track-label: 0.12em;  /* instrument label small-caps (meter tick feel) */

    --radius-card: 0.5rem;
    --radius-meter: 0.75rem; /* instrument panel — one notch larger */
    --radius-chip: 999px;

    /* Hero logo sweep period = 4 beats @ 128 BPM (the page's tempo anchor). */
    --logo-period: 1.875s;

    --max-content: 64rem;   /* wider than hub (56rem) — product-as-hero */
    --max-wide: 80rem;      /* hero / module 2-col outer frame */
    --reading: 40rem;       /* inner prose column */
  }

  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  html {
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-body);
    font-size: var(--fs-base);
    line-height: var(--lh-normal);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    /* defensive: never let a stray wide child create horizontal scroll
       (which reads as an asymmetric / left-shifted page). position:relative so
       absolutely-positioned descendants (e.g. .skip-link) are contained by
       this clipping box and can't extend the <html> scroll width. */
    position: relative;
    overflow-x: clip;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  main { flex: 1 0 auto; width: 100%; }

  a { color: inherit; }

  :focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    font-weight: 600;
    line-height: var(--lh-tight);
    letter-spacing: var(--track-display);
    margin: 0;
  }

  /* Japanese loosens the tight display tracking. */
  :lang(ja) h1, :lang(ja) h2, :lang(ja) h3, :lang(ja) h4 {
    letter-spacing: 0;
  }

  /* sr-only via clip — off-screen left:-9999px caused horizontal scroll
     (the link extended the scrollable area, shifting the page). Clip has zero
     layout footprint, so no scroll. Revealed on focus. */
  .skip-link {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    background: var(--fg);
    color: var(--bg);
    padding: 0;
    z-index: 60;
  }
  .skip-link:focus {
    width: auto;
    height: auto;
    overflow: visible;
    clip: auto;
    clip-path: none;
    left: var(--space-sm);
    top: var(--space-sm);
    padding: var(--space-2xs) var(--space-sm);
  }

  /* ===== Shared section utilities ===== */
  .section {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding-inline: clamp(1.25rem, 0.5rem + 3vw, 4rem);
    padding-block: var(--space-section);
  }

  .section--narrow { max-width: var(--max-content); }

  /* Alternating band background to separate stacked module/sections. */
  .band-1 { background: var(--bg-1); }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--track-label);
    color: var(--muted);
    margin: 0 0 var(--space-sm);
  }

  .section-heading {
    font-size: var(--fs-xl);
    color: var(--fg);
    margin: 0 0 var(--space-md);
  }

  .section-lede {
    color: var(--muted);
    font-size: var(--fs-lg);
    line-height: var(--lh-normal);
    max-width: var(--reading);
    margin: 0 0 var(--space-xl);
  }

  /* ===== CTA button ===== */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    background: var(--cta-bg);
    color: var(--cta-fg);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-base);
    text-decoration: none;
    padding: var(--space-xs) var(--space-lg);
    border-radius: var(--radius-chip);
    border: 1px solid transparent;
    box-shadow: var(--glow-cta);
    transition: background-color 140ms ease, transform 140ms ease;
  }
  .btn-cta:hover { background: var(--cta-bg-hover); transform: translateY(-1px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    background: transparent;
    color: var(--cta-ghost-fg);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-base);
    text-decoration: none;
    padding: var(--space-xs) var(--space-lg);
    border-radius: var(--radius-chip);
    border: 1px solid var(--cta-ghost-border);
    transition: border-color 140ms ease, color 140ms ease;
  }
  .btn-ghost:hover { border-color: var(--cta-ghost-fg); color: var(--fg); }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .btn-cta:hover { transform: none; }
    *, *::before, *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
    }
  }
</style>
