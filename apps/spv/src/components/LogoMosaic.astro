---
// LogoMosaic — the animated SPV-2 brand logo: a 14×20 grid of 280 colored
// tiles (teal → green → amber spectrum) that lights up like city neon.
//
// Choreography (v2): a ~28s loop of 8 phases that cross-fade into each other —
//   awaken (slow sparse blink) → diagonal → vertical → horizontal → radial
//   burst → random flicker → full pulse → settle (back to awaken).
// Each tile carries the PHASE for every pattern, baked at build time as
// --p0..--p7 custom props. One shared keyframes (neon-pulse) animates only
// brightness / scale / opacity / a faint glow; per-phase the root gets a
// data-pattern that swaps which phase var drives animation-delay, plus gain /
// period / easing. A tiny setTimeout chain advances the phases; with JS off it
// falls back to the diagonal sweep, and prefers-reduced-motion freezes it to
// the static mosaic. Tiles never change color — neon lifts brightness only.

import tiles from '../data/logo-tiles.json' with { type: 'json' };

const MAX_X = 120.25;
const MAX_Y = 123.02;

// Deterministic hash (stable across builds, unlike Math.random).
const hash = (a: number, b: number) => {
  const s = Math.sin(a * 127.1 + b * 311.7) * 43758.5453;
  return s - Math.floor(s);
};
const clamp01 = (v: number) => Math.max(0, Math.min(1, v));
const r3 = (v: number) => Math.round(v * 1000) / 1000;

type Tile = { x: number; y: number; w: number; h: number; rx: number; r: number; g: number; b: number };

const baked = (tiles as Tile[]).map((t) => {
  const nx = t.x / MAX_X;
  const ny = t.y / MAX_Y;
  const dist = Math.hypot(nx - 0.5, ny - 0.5) / 0.7071; // 0 center → 1 corner
  const r0 = hash(t.x, t.y);
  const r5 = hash(t.y * 1.3, t.x * 0.7);
  const lum = 0.2126 * t.r + 0.7152 * t.g + 0.0722 * t.b;
  return {
    ...t,
    p0: r3(r0),                          // sparse blink (random)
    p1: r3((nx + (1 - ny)) / 2),         // diagonal ↗
    p2: r3(ny),                          // vertical ↓ (top first)
    p3: r3(nx),                          // horizontal →
    p4: r3(1 - clamp01(dist)),           // radial burst (center first)
    p5: r3(r5),                          // random flicker (other seed)
    p7: r3(clamp01(dist)),               // settle (outer → inner)
    lit0: r0 < 0.18 ? 1 : 0,             // 18% lit during awaken
    bright: lum > 180,
  };
});
---

<div class="logo-wrap">
  <div class="logo-mosaic" data-instrument data-playing aria-hidden="true">
    <svg viewBox="0 0 128 128" role="img" aria-label="SPV-2">
      {baked.map((t) => (
        <rect
          class="tile"
          x={t.x}
          y={t.y}
          width={t.w}
          height={t.h}
          rx={t.rx}
          fill={`rgb(${t.r},${t.g},${t.b})`}
          data-bright={t.bright ? '' : undefined}
          style={`--p0:${t.p0};--p1:${t.p1};--p2:${t.p2};--p3:${t.p3};--p4:${t.p4};--p5:${t.p5};--p7:${t.p7};--lit0:${t.lit0}`}
        />
      ))}
    </svg>
  </div>
  <div class="logo-controls">
    <button class="logo-btn logo-stop" type="button" aria-pressed="false" aria-label="Pause logo animation">
      <svg class="logo-btn__icon" viewBox="0 0 16 16" aria-hidden="true">
        <rect class="logo-stop__pause" x="4.5" y="3.5" width="2.5" height="9" rx="0.5" />
        <rect class="logo-stop__pause" x="9" y="3.5" width="2.5" height="9" rx="0.5" />
        <path class="logo-stop__play" d="M5 3.5 L12.5 8 L5 12.5 Z" />
      </svg>
    </button>
    <button class="logo-btn logo-next" type="button" aria-label="Next pattern">
      <svg class="logo-btn__icon" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M2.5 3.5 L8 8 L2.5 12.5 Z" />
        <path d="M8.5 3.5 L14 8 L8.5 12.5 Z" />
      </svg>
    </button>
  </div>
</div>

<style>
  /* --wave-gain (0..1) is the global "amount of light change". Registered so it
     can be CSS-transitioned: JS just flips the target between 0 and 1 at phase
     boundaries, and the browser eases the ramp (no per-frame JS). At 0 the wave
     flattens to a still mosaic ("did it stop?"); the next pattern's direction is
     swapped while it's 0, then it eases back up. Tiles derive --neon-gain from
     it via a plain (unregistered) calc — only --wave-gain transitions. */
  @property --wave-gain {
    syntax: '<number>';
    inherits: true;
    initial-value: 0;
  }

  .logo-wrap {
    width: max-content;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-end; /* stop button sits at the logo's right edge, below */
  }

  .logo-mosaic {
    width: clamp(280px, 36vw, 520px);
    aspect-ratio: 1;
    /* no backing panel — float on the page's black. */
    /* position:relative so the ::before glow (inset:-8%) is sized to THIS box,
       not a far positioned ancestor. Without it the glow's containing block was
       <body>, stretching it to 108% of the whole page = a huge phantom region
       (~757px) of empty scrollable space below the footer. */
    position: relative;
    --wave-gain: 0;
    transition: --wave-gain var(--wave-ramp, 1600ms) ease-in-out;
  }

  /* ambient glow stands in for the removed panel: "a light source is here". */
  .logo-mosaic::before {
    content: '';
    position: absolute;
    inset: -8%;
    background: radial-gradient(closest-side, rgba(0, 255, 200, 0.07), rgba(0, 255, 200, 0) 70%);
    filter: blur(20px);
    z-index: -1;
    pointer-events: none;
  }

  .logo-mosaic svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .tile {
    transform-box: fill-box;
    transform-origin: center;
    /* slower base period — "wait, is something moving?" pace.
       `both` so tiles sit at the 0% baseline before their (positive) delay
       elapses — the wave visibly ENTERS from the phase-0 edge rather than
       appearing already in motion. */
    animation: neon-pulse var(--neon-period, 3.75s) var(--neon-ease, ease-in-out) infinite both;
    /* positive delay → each pattern starts from its head (wave sweeps in). */
    animation-delay: calc(var(--p1) * var(--neon-period, 3.75s));
  }

  /* will-change only while actively playing (avoid 280 permanent layers) */
  .logo-mosaic[data-playing] .tile {
    will-change: transform, opacity;
  }

  /* Wave amplitude lives in --wave-gain, ramped by JS (rAF) between 0 and 1.
     Direction (animation-delay) is swapped only while wave-gain is ~0, so a
     pattern change crossfades through a flat calm mosaic — never a hard snap.
     The per-pattern block below derives each tile's --neon-gain from it. */

  /* EVERY frame is baseline + gain × delta, so at gain 0 all frames collapse to
     the SAME still value (opacity .85 / brightness 1 / scale 1). That means
     when --wave-gain is 0 the animation is visually frozen no matter each
     tile's animation-delay — so swapping the pattern (direction) at gain 0 can
     never produce a visible jump. As gain rises, the wave shape emerges. */
  @keyframes neon-pulse {
    0% {
      opacity: calc(0.85 - 0.05 * var(--neon-gain, 0));
      filter: brightness(calc(1 - 0.08 * var(--neon-gain, 0)));
      transform: scale(1);
    }
    10% {
      opacity: calc(0.85 + 0.15 * var(--neon-gain, 0));
      filter: brightness(calc(1 + 0.55 * var(--neon-gain, 0)))
              drop-shadow(0 0 calc(2px * var(--neon-gain, 0)) rgba(255, 255, 255, 0.28));
      transform: scale(calc(1 + 0.055 * var(--neon-gain, 0)));
    }
    26% {
      opacity: calc(0.85 + 0.05 * var(--neon-gain, 0));
      filter: brightness(calc(1 + 0.05 * var(--neon-gain, 0)));
      transform: scale(calc(1 + 0.012 * var(--neon-gain, 0)));
    }
    55% {
      opacity: calc(0.85 - 0.01 * var(--neon-gain, 0));
      filter: brightness(calc(1 - 0.03 * var(--neon-gain, 0)));
      transform: scale(1);
    }
    74% {
      opacity: calc(0.85 + 0.03 * var(--neon-gain, 0));
      filter: brightness(1);
      transform: scale(calc(1 + 0.004 * var(--neon-gain, 0)));
    }
    100% {
      opacity: calc(0.85 - 0.05 * var(--neon-gain, 0));
      filter: brightness(calc(1 - 0.08 * var(--neon-gain, 0)));
      transform: scale(1);
    }
  }

  /* ===== per-phase: each pattern sets only DIRECTION (animation-delay) +
     period/ease + a peak ceiling (--peak-gain). Amplitude itself is the global
     --wave-gain ramped by JS; the tile's effective gain = wave-gain × peak.
     Direction is swapped only while wave-gain is ~0, so changes crossfade
     through a flat calm mosaic — no snap. Delays POSITIVE = wave enters from
     the phase-0 edge. Periods slow = "barely moving". */
  .logo-mosaic { --peak-gain: 0.8; }
  .tile { --neon-gain: calc(var(--wave-gain, 0) * var(--peak-gain, 0.8)); }

  .logo-mosaic[data-pattern='awaken'] { --peak-gain: 0.55; }
  .logo-mosaic[data-pattern='awaken'] .tile {
    --neon-period: 5.6s;
    /* unlit tiles stay near-still; only the 18% lit ones blink */
    --neon-gain: calc(var(--wave-gain, 0) * 0.55 * var(--lit0, 1));
    animation-delay: calc(var(--p0) * 5.6s);
  }

  .logo-mosaic[data-pattern='diagonal'] { --peak-gain: 0.8; }
  .logo-mosaic[data-pattern='diagonal'] .tile { animation-delay: calc(var(--p1) * var(--neon-period, 3.75s)); }

  .logo-mosaic[data-pattern='vertical'] { --peak-gain: 0.85; }
  .logo-mosaic[data-pattern='vertical'] .tile { animation-delay: calc(var(--p2) * var(--neon-period, 3.75s)); }

  .logo-mosaic[data-pattern='horizontal'] { --peak-gain: 0.85; }
  .logo-mosaic[data-pattern='horizontal'] .tile { animation-delay: calc(var(--p3) * var(--neon-period, 3.75s)); }

  .logo-mosaic[data-pattern='radial'] { --peak-gain: 0.95; }
  .logo-mosaic[data-pattern='radial'] .tile { animation-delay: calc(var(--p4) * var(--neon-period, 3.75s)); }

  .logo-mosaic[data-pattern='flicker'] { --peak-gain: 1.0; }
  .logo-mosaic[data-pattern='flicker'] .tile {
    --neon-period: 2.4s;
    --neon-ease: steps(2, end);
    animation-delay: calc(var(--p5) * 2.4s);
  }

  .logo-mosaic[data-pattern='pulse'] { --peak-gain: 0.9; }
  .logo-mosaic[data-pattern='pulse'] .tile { --neon-period: 3s; animation-delay: 0s; }

  .logo-mosaic[data-pattern='settle'] { --peak-gain: 0.6; }
  .logo-mosaic[data-pattern='settle'] .tile { animation-delay: calc(var(--p7) * var(--neon-period, 3.75s)); }

  /* paused (stop button or offscreen): freeze + wave-head snapshot */
  .logo-mosaic:not([data-playing]) .tile { animation-play-state: paused; }

  /* ===== controls — tiny, unobtrusive, below the logo's right edge ===== */
  .logo-controls {
    margin-top: var(--space-2xs);
    display: inline-flex;
    gap: var(--space-3xs);
  }
  .logo-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 50%;
    color: var(--muted-2);
    cursor: pointer;
    opacity: 0.4;
    transition: opacity 140ms ease, color 140ms ease;
  }
  .logo-wrap:hover .logo-btn { opacity: 0.75; }
  .logo-btn:hover,
  .logo-btn:focus-visible { opacity: 1; color: var(--fg); }
  .logo-btn__icon { width: 13px; height: 13px; display: block; fill: currentColor; }
  /* playing → show pause bars; paused → show play triangle */
  .logo-stop__play { display: none; }
  .logo-stop[aria-pressed='true'] .logo-stop__pause { display: none; }
  .logo-stop[aria-pressed='true'] .logo-stop__play { display: block; }

  @media (prefers-reduced-motion: reduce) {
    .tile { animation: none !important; }
    .tile[data-bright] { filter: brightness(1.13); }
    .logo-controls { display: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.logo-wrap').forEach((wrap) => {
    const mosaic = wrap.querySelector<HTMLElement>('.logo-mosaic');
    const stopBtn = wrap.querySelector<HTMLButtonElement>('.logo-stop');
    const nextBtn = wrap.querySelector<HTMLButtonElement>('.logo-next');
    if (!mosaic) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return; // static mosaic; no timers, no controls needed

    const PATTERNS = ['awaken', 'diagonal', 'vertical', 'horizontal', 'radial', 'flicker', 'pulse', 'settle'];

    // Timeline per pattern (ms). JS only flips the --wave-gain TARGET (0 or 1);
    // CSS transitions ease the actual ramp, so there's no per-frame JS.
    //   gain→1 (wave swells in, RAMP) · HOLD (full wave) · gain→0 (settles to a
    //   still mosaic — "did it stop?") · CALM (rest) · swap direction · repeat.
    const RAMP = 1600; // must match the CSS --wave-ramp transition
    const HOLD = 9000; // full-amplitude wave time
    const CALM = 2200; // still rest at gain 0 between patterns
    // Auto-stop after ~5 min of running so an idle tab doesn't animate forever.
    // It stops gracefully at a settle (still mosaic), not mid-wave, and the user
    // can resume with the stop/play button. ~5 min ≈ a few songs — fits a music
    // tool's sense of time without cutting off normal reading.
    const AUTO_STOP_MS = 5 * 60 * 1000;

    let i = 0;
    let timer = 0;
    let runMs = 0;        // accumulated running time toward the auto-stop budget
    let legStart = 0;     // wall-clock start of the current leg
    let onScreen = true;
    let userPaused = false;
    let autoStopped = false;
    let running = false;

    // Advance through: enter(swap dir + ramp up) → hold → settle(ramp down) →
    // rest(calm) → enter(next) … Each leg is one setTimeout. No rAF.
    const enter = () => {
      mosaic.setAttribute('data-pattern', PATTERNS[i]); // swap while gain is 0
      i = (i + 1) % PATTERNS.length;
      mosaic.style.setProperty('--wave-gain', '1'); // CSS eases 0→1
      legStart = performance.now();
      timer = window.setTimeout(settle, RAMP + HOLD);
    };
    const settle = () => {
      mosaic.style.setProperty('--wave-gain', '0'); // CSS eases 1→0
      runMs += performance.now() - legStart;
      if (runMs >= AUTO_STOP_MS) {
        // budget spent — stop here, at the still mosaic. Show the play state.
        autoStopped = true;
        running = false;
        clearTimeout(timer);
        timer = 0;
        mosaic.removeAttribute('data-playing');
        stopBtn?.setAttribute('aria-pressed', 'true');
        stopBtn?.setAttribute('aria-label', 'Resume logo animation');
        return;
      }
      legStart = performance.now();
      timer = window.setTimeout(enter, RAMP + CALM); // rest at 0, then next
    };

    const play = () => {
      if (running || userPaused || autoStopped || !onScreen) return;
      running = true;
      mosaic.setAttribute('data-playing', '');
      enter();
    };
    const halt = () => {
      running = false;
      clearTimeout(timer);
      timer = 0;
      mosaic.removeAttribute('data-playing');
    };

    // Next: settle now, then the next pattern enters after the rest — always
    // through the gain-0 bottom, so it eases rather than snapping.
    const skipNext = () => {
      if (userPaused || !running) return;
      clearTimeout(timer);
      settle();
    };

    play();

    const io = new IntersectionObserver(
      ([e]) => {
        onScreen = e.isIntersecting;
        if (onScreen) play();
        else halt();
      },
      { threshold: 0 }
    );
    io.observe(mosaic);

    stopBtn?.addEventListener('click', () => {
      const stopped = userPaused || autoStopped;
      if (stopped) {
        // resume — fresh auto-stop budget
        userPaused = false;
        autoStopped = false;
        runMs = 0;
        stopBtn.setAttribute('aria-pressed', 'false');
        stopBtn.setAttribute('aria-label', 'Pause logo animation');
        play();
      } else {
        userPaused = true;
        stopBtn.setAttribute('aria-pressed', 'true');
        stopBtn.setAttribute('aria-label', 'Resume logo animation');
        halt();
      }
    });

    nextBtn?.addEventListener('click', skipNext);
  });
</script>
